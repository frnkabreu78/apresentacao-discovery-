ráfego pago (Meta Ads) e Saltos de expansão (importações da China, loja física, maquinário), com setas azuis. Barra inferior verde com estrelas: lojistas maduros autofinanciam com desconto à vista no Pix ou operam dropship/just-in-time; o dinheiro da operação não fica preso no estoque, sangra em marketing e expansão.";function Kh(){return s.jsxs("section",{className:"pres-myth-slide pres-myth-slide--asset","aria-labelledby":"sec-alem-superficie-ciclo-financeiro",children:[s.jsx("h2",{className:"pres-sr-only",id:"sec-alem-superficie-ciclo-financeiro",children:"O Descasamento de Caixa para Estoque Não é a Dor Principal"}),s.jsx(Ha,{src:Zh,alt:Jh})]})}const wh="/descasamento-caixa-nao-e-dor-principal.png",Fh="Infográfico 3D claymorphism, fundo branco: «Além da superfície: o verdadeiro ciclo financeiro dos lojistas» em letras volumétricas azul e branco; subtítulo em castanho escuro sobre resultados da pesquisa qualitativa de crédito e próximos passos estratégicos. Linha azul espessa separa Superfície (checkout digital com carrinho, percentagem e botão CHECKOUT com cursor; à direita personagem a organizar caixas de cartão) do Subsolo. Subsolo: tubagens cinzentas com fluxo de caixa, capital de giro, custos operacionais e fornecedores, com caixas cinzentas, setas para baixo e dólares; tubo laranja proeminente com saco de dinheiro, rótulos gargalo financeiro e atrito no crédito; rede verde com oportunidade de capital e investimentos, moedas de ouro a sair de uma válvula e seta para alavanca estratégica; à direita tubo cinzento «Empréstimos» com ícone de dólar amarelo por cima. Caixa branca com contorno azul «O ponto crítico»: ofertamos crédito para um sintoma que não dói; pesquisa com 8 lojistas sobre atrito do modelo e alavancas reais para adoção de capital.";function Ih(){return s.jsxs("section",{className:"pres-myth-slide pres-myth-slide--asset pres-myth-slide--intrinsic-size","aria-labelledby":"sec-descasamento-caixa-nao-dor-principal",children:[s.jsx("h2",{className:"pres-sr-only",id:"sec-descasamento-caixa-nao-dor-principal",children:"Além da superfície: o verdadeiro ciclo financeiro dos lojistas"}),s.jsx(Ha,{src:wh,alt:Fh})]})}const Ph="/arquetipos-comportamentais-base.png",$h="Arquétipos comportamentais — infográfico horizontal com três cartões brancos arredondados e ícones 3D. Os Caixa Forte (Aline, Andressa, Viviane): gestão hiper-estruturada; capital próprio como alavanca principal; aversão forte a dívidas comerciais e juros; são os seus próprios bancos. Os Ágeis e On-Demand (Douglas, Mayke, Gaby): dropshipping e produção just-in-time; sem estoque físico; margem alta com ciclo financeiro curtíssimo (1 a 2 dias); reinvestimento imediato. Varejo Raiz e Escaladores (Joyce, Estela): inventário físico denso e complexo; dependentes de giro contínuo de caixa; investimento constante em tráfego pago para sobreviver.";function Wh(){return s.jsxs("section",{className:"pres-myth-slide pres-myth-slide--asset","aria-labelledby":"slide-arquetipos-heading",children:[s.jsx("h2",{className:"pres-sr-only",id:"slide-arquetipos-heading",children:"Arquétipos comportamentais — Caixa Forte, Ágeis e On-Demand, Varejo Raiz e Escaladores"}),s.jsx(Ha,{src:Ph,alt:$h})]})}const ev="/media/aderencia-arquetipo-2-ageis-on-demand.png",av="Análise de Aderência: Arquétipo 2 — Os Ágeis & On-Demand (Douglas, Mayke, Gaby). Barra No-Go para giro vs GO para importação/ads; engrenagens com retenção passiva. Falso problema: sem dor de descasamento, capital gira em 1 a 2 dias. Fricção da cobrança: retenção paralisa a operação e exige pagamento ativo. Citação de Douglas sobre evitar crédito a 30 dias e empréstimo só para escalar.";function sv(){return s.jsxs("section",{className:"pres-myth-slide pres-myth-slide--asset","aria-labelledby":"sec-aderencia-arquetipo-2",children:[s.jsx("h2",{className:"pres-sr-only",id:"sec-aderencia-arquetipo-2",children:"Análise de Aderência: Arquétipo 2 — Os Ágeis e On-Demand"}),s.jsx(Ha,{src:ev,alt:av})]})}const lv="/media/aderencia-arquetipo-3-varejo-raiz-escaladores.png",iv="Análise de Aderência: Arquétipo 3 — Varejo Raiz e Escaladores (Aline, Andressa, Viviane, Estela). Veredito GO estratégico com aviso de pivô nas regras. Gráfico curva de ativação vs tempo e engajamento. Onde encaixa: microcrédito de ciclo curto para reposição; financiamento de longo prazo para campanhas de marketing. Barreira: rejeitam rigidez de parcelas únicas para giro rápido e desconfiança na retenção passiva. Citação de Estela sobre faturamento e tráfego pago.";function ov(){return s.jsxs("section",{className:"pres-myth-slide pres-myth-slide--asset","aria-labelledby":"sec-aderencia-arquetipo-3",children:[s.jsx("h2",{className:"pres-sr-only",id:"sec-aderencia-arquetipo-3",children:"Análise de Aderência: Arquétipo 3 — Varejo Raiz e Escaladores"}),s.jsx(Ha,{src:lv,alt:iv})]})}const tv={Estela:"Estela Zanforlin",Joyce:"Joyce","Douglas Eusébio":"Douglas Eusébio","Mayke Gomes":"Mayke Gomes","Andressa Sanches":"Andressa Sanches","Gaby Trus":"Gaby Trus",Aline:"Aline Sorelah",Viviane:"Viviane"};function rv(c){const z=c.indexOf(" — ");return z===-1?c.trim():c.slice(z+3).trim()}function nv(c){const A=c.trim(),z=tv[A];if(!z)return null;const p=ro.find(L=>L.profileName===z);if(!(p!=null&&p.media.videoSrc))return null;const R=p.media.videoLabel??"";return{citedBy:A,media:p.media,shopLabel:rv(R)}}const Tt=[{id:"dovetail-transcript-2026-04-14 (1)-0-f508cc96a7",theme:"Contexto da loja e operação",quote:"minha formação é outra E depois de 21 anos trabalhando numa área, E aí eu fiz uma sociedade com a minha irmã, que também tava querendo mudar um pouco o rumo dela. porque a gente não queria sair dessa coisa do tema poético, que é importante para a nossa marca. É um cara lá do Mato Grosso que cismou com a gente e é o fim do mundo. E aí a poesia com Y virou ateliê poesia e nós estamos na briga de novo, porque ele também não quer nos deixar o ateliê poesia.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-1-5d4c247e9a",theme:"Contexto da loja e operação",quote:"a gente abriu já direto o e-commerce Mas a gente não dava muita bola para ele A gente fazia mais venda presencial, mas a gente sabia que desde o começo seria importante ter uma presença ali no comércio online. Eu estou contando essa história do nome porque eu acho que isso é importante para falar sobre a nossa história. Quando a gente pensa em branding da marca, de tudo que a gente sonhou para a marca, você ficar mudando de nome é péssimo.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-2-1357dd52ec",theme:"Contexto da loja e operação",quote:"para a gente conseguir ali uma autoridade no Google Porque cada hora a gente tem que pedir, vão mudar o nome Aí tudo muda tudo de novo e tal Então a gente teve esse reverse com relação ao site Por ter que ficar trocando de nome, vocês devem ouvir muito essa história, a gente voltou 100% para o digital e ali a gente começou a trabalhar efetivamente para melhorar o site e a gente conseguir vender mais pelo site.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-3-1ba72515e6",theme:"Tráfego pago, mídia e aquisição",quote:"Como a gente conseguiu vender mais pelo site na pandemia, a gente achou que seria um caminho melhor Focar mais no site do que no presencial, então a gente diminuiu por quase completo presencial Tenho só duas lojas só que a gente atende e estamos assim 100% no online Ali a gente começou com tráfego pago, fizemos com dois consultores que não deram resultado ele é muito bom e desde o começo com ele a gente começou a ter muito resultado. E aí a gente vem aprimorando ali ao longo desse tempo.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-4-2148c50f2a",theme:"Fornecedor, estoque e logística",quote:"tem um percurso diferente do da revenda. Eu já paguei o fornecedor e aí... Ou melhor, eu já vendi a peça e ainda estou lá pagando o fornecedor, A gente teve uma dificuldade nesses últimos anos que... e aí eu vejo uma dificuldade grande para o nosso crescimento, esse prazo enorme que eu tenho para conseguir pagar o fornecedor e vender as peças. você faz uma por uma e demora um século e tem lá três itens pra vender, quando você faz semijói em fundição, eu tenho que fazer cem itens de cada peça.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-5-cbe5f3c3f5",theme:"Crédito, empréstimo, CET e bancos",quote:"eu amargurei o prejuízo da coleção inteira, que eu acho que também é de todo mundo. a gente faz a opção de pagamento em três vezes sem juros para o cliente. porque eu acredito que ainda é uma opção melhor, mas 10,78% acho que é de taxa para mim. essa coisa da taxa é algo que me dificulta.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-6-29d9b8285c",theme:"Contexto da loja e operação",quote:"o relatório de recebimento que a gente tinha ali na mão, E agora mudou para você ter que pedir um relatório para o consultor, eu achei isso muito ruim também Eu gostava de ter aquilo fácil, Normalmente eu peço resgate do valor que está disponível para mim em determinado dia da semana amanhã eu vou receber 3 mil e quinta-feira eu vou receber 2,5 mil Então eu vou esperar sexta-feira para pedir o resgate, porque tem a taxa para você solicitar o resgate também Então isso era muito prático.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-7-f80503354f",theme:"Contexto da loja e operação",quote:"Porque no dia-a-dia não dá tempo de ficar clicando pra chamar o consultor, me mandar o negócio E o relatório não é tão prático e tão, assim, velho Então isso eu acho uma coisa que Outra coisa que eu acho que seria legal, que eu não sei se já tem essa funcionalidade, mas é a data de nascimento do cliente, ali a hora que ele preenche o cadastro do aniversário, para a gente ficar com essa informação fácil do aniversário, eu acho que aí fica por conta de eu mesmo ter que melhorar.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-8-a706401511",theme:"Contexto da loja e operação",quote:"E a gente fez mudanças no site no ano passado, por conta de uma mentoria que eu fiz com a Marcina Prática. A nossa mentora Fabiana nos auxiliou e nos mostrou o que a gente podia dar no site para melhorar, e a gente já fez isso. Eu acho que com relação a isso agora tá ok. Eu acho que isso vem desde o ano passado, E ele está achando que isso é por conta de uma lentidão no site.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-9-cfbbeceadf",theme:"Plataforma, Nuvemshop e integrações",quote:"Ontem ele tirou uma barrinha de frete grátis, a gente não tá muito sabendo o que que é, e a gente entrou em contato com o time da Nuvemshop também, deram uma sugestão lá também para fazer, Eu não sei se é por aí que vocês querem conversar comigo, não sei se estou indo pelo caminho certo, pode perguntar o que vocês quiserem, que vocês estão querendo saber o que vocês, de uma visão de uma pessoa que tá desde 2018. Naquela barrinha que aparece agora para acessar os extratos.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-10-65ebedab36",theme:"Marketplace, canais e omnicanal",quote:"Nós estamos modificando e em breve você terá acesso novamente. Porque parece que tiraram a transparência. se eu tivesse lido no primeiro dia que vocês só estavam melhorando pra voltar um negócio super legal, Eu vendo 90% pela Nuvemshop e 10% pelo WhatsApp. Se eu tenho alguma dificuldade com relação a alguma nota, alguma coisa que fuja do meu BH do dia a dia, Eu vi que a Nuvemshop agora começou a...",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-11-35f3bfb6f3",theme:"Plataforma, Nuvemshop e integrações",quote:"Eu não sei se é esse o objetivo da plataforma, porque tá fazendo a nota fiscal e tal, ele não é didático Várias coisas eu não consigo fazer sozinha, eu não consigo fazer com o suporte deles E eu tenho que pagar para o suporte premium me ajudar. Isso já aconteceu acho que umas duas ou três vezes Aí quando você paga o suporte premium, porque eles ficam ali duas horas com você, só que aí o Duran fica pagando toda vez, se eu tivesse mais dados na Nuvemshop, Eu testei recentemente aquele aplicativo...",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-12-7712c549e4",theme:"Plataforma, Nuvemshop e integrações",quote:"Ai, Ele mostra uns outros dados dentro da Nuvemshop, porque ele tem a conexão com a Nuvemshop, só que ele ainda é meio caro para mim, Se esses dados viessem junto na plataforma da Nuvemshop, Só com relação às vendas e que estado e tal lá naquele dashboard do Bling. como ele ficou ali junto com a estatística, porque era só um período de teste gratuito.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-13-7af9f14a5b",theme:"Fornecedor, estoque e logística",quote:"Eu fiz bastante aulinha para entender qual que era o meu produto estrela e não deixar faltar o estoque, eu tenho um produto estrela que é o Bracelete Onda, A gente previu um tanto de venda em dezembro e a gente vendeu muito mais. E aí eu ficar sem significa que eu vou ter esse produto só depois de uns três meses. mas por que ela erra se ela sabe que ela tem que ter, Eu lancei uma coleção nova em dezembro e a gente apostou que ia pulverizar ia vender o que tem no site e o produto estrela.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-14-6a68609f4f",theme:"Crédito, empréstimo, CET e bancos",quote:"como que eu vou adivinhar o que o cliente tá querendo, acho que uma das maiores dificuldades, pra gente... A gente coloca um monte de estoque numa peça, de repente as pessoas começam a comprar outra. agora eu tô conseguindo parcelar mais Eu consigo parcelar em três, quatro vezes com os que eu tenho um valor maior de fundição Peças que eu compro pouca quantidade e não consigo, eu consigo parcelar entre 5 e 6 vezes e sempre no cartão.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-15-d7e970411c",theme:"Crédito, empréstimo, CET e bancos",quote:"a maioria no boleto ou PIX agendado Entendi, porque eu tenho que fazer muitas peças, ah, eu vou lá no fornecedor e compro 12 peças, logo eu tô sabendo quando tá a cesta, eu já consigo me programar pra fazer, pagando aquela conta de dezembro e eu já tenho que fazer uma comprona de 100 de novo? Eu não recorro a crédito externo Eu não tenho o perfil muito de arriscar, Eu não faço dívida que eu não possa pagar. Talvez até se eu tivesse feito créditos, Eu acho que talvez o receio de não conseguir pagar, de...",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-16-29242ca146",theme:"Crédito, empréstimo, CET e bancos",quote:"O crescimento me assusta um pouco, e aí eu somar isso a um empréstimo... eu acho que por enquanto o cartão de crédito me atende por causa desse meu perfil mais cartesiano, Eu posso vir mais pra frente até pensar num crédito assim, E eu acho assim que também a política no Brasil é muito instável.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-17-1acb545e46",theme:"Contexto da loja e operação",quote:"Então vai saber se o mês que vem o ouro vai estar triplicado e já não seja um bom negócio para a minha empresa e eu desisto, eu tenho outras coisas que vão além da inflação, eles deixaram de investir em dólar para investir em ouro. os chineses pegam todo o ródeo para fazer equipamento, era um produto que eu tinha que era muito bom, porque o ródeo não amarela como a prata, não posso usar Então tem essas variações que vão além das políticas do governo, né? Eu acho que é pelo meu perfil mesmo.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-18-8be9786dad",theme:"Crédito, empréstimo, CET e bancos",quote:"Eu acho que eu sou a cliente ideal pra esse produto. Eu acho que é uma questão de perfil controlador. Uma pessoa que tem um perfil mais controlador, você vai ver isso na minha conta de banco CPF Estela, O gerente vai me oferecer lá mil opções, não tem risco Eu não vou no CDB do Banco Master, Se eu for no CDB ou é do Banco do Brasil ou é do Itaú, Então esse perfil no CPF talvez não seja o melhor perfil para lidar, com o e-commerce e ser mais arrojada no comércio e tal Talvez se eu tivesse um funcionário para cuidar da parte financeira para mim Talvez ele me viesse com essa ideia e me explicasse A por B, porque é bom Mas eu acho que não é uma...",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-19-aa415ea246",theme:"Crédito, empréstimo, CET e bancos",quote:"Eu acho que investir e ter esse comportamento de fazer um crédito vai muito da pessoa, Eu aceitaria desde que essa pessoa assumisse os riscos. eu estou tentando abaixar os custos da minha loja, Pela taxa que tem sido aplicada e pelo custo da minha matéria-prima que só aumenta. Eu fazer um crédito para...",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-20-acf0cb5661",theme:"Crédito, empréstimo, CET e bancos",quote:"Não existe crédito sem juros, E aí eu assumir mais esses outros juros, eu não me sinto confortável Eu fazer uma dívida para conseguir tampar um buraco de uma coisa que eu acho que eu não tô conseguindo melhorar ali, uma coisa que o Henrique sempre insiste e coloca pra mim Você tem que investir mais em tráfego O tráfego come uma parte enorme do meu caixa do dia a dia. Porque você tem que pagar aquilo... Eu normalmente...",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-21-be4fbb93d7",theme:"Crédito, empréstimo, CET e bancos",quote:"Olha o meu perfil, Pra não ter medo de ficar indo pro cartão de crédito e eu perder o controle, eu acho que se eu tivesse mais recurso para o tráfego, Só que aí me falta para fazer outra coleção, me falta para comprar as mil caixas. A gente vê que é um dinheiro que eu coloco e que ele me dá retorno. Eu acredito piamente que o meu faturamento hoje vem do tráfego. eu acho que eu preciso ter a opção de pagar aquilo. Eu gosto de ter a opção de pagar aquilo. Algumas coisas só que eu coloco no débito automático.",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (1)-22-c85e3fe6b9",theme:"Contexto da loja e operação",quote:"Essas outras coisas eu acho que eu prefiro ter mais controle,",citedBy:"Estela"},{id:"dovetail-transcript-2026-04-14 (2)-0-b7636842e1",theme:"Marketplace, canais e omnicanal",quote:"A minha loja a princípio começou com vendas de acessórios para celular, então já estamos indo para seis anos. no decorrer ali das coisas eu acabei migrando para capinhas personalizadas, então fui tirando um pouquinho os acessórios e focando as capas personalizadas, e hoje eu tô ampliando para outros itens personalizados também, a princípio sempre foi um maior foco fazer o site crescer, Aí do Mercado Livre eu fiquei só com o site e hoje eu tô com, e aí hoje eu tô com o site e a Nuvemshop.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-1-996a5fc30a",theme:"Plataforma, Nuvemshop e integrações",quote:"hoje o meu foco maior está nas duas plataformas, e um pouco disso pela dificuldade que eu tenho de cadastrar os meus produtos com a Nuvemshop, se tivesse o campinho para subir as imagens por link, Então tem como fazer essa em massa por imagem, então tem que subir os produtos e depois ir colocando as imagens manualmente e assim, hoje eu trabalho com 375 modelos de celular, E aí a Samsung para me ajudar tá lançando mais uma linha que é o S26, então a gente vai aumentar mais ainda isso daí.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-2-edef743c01",theme:"Marketplace, canais e omnicanal",quote:"E aí querendo ou não faço o cadastro por estampa, então assim São 375 vezes 200 estampas Aí isso dificulta muito na hora de eu fazer o cadastro Já na Shopee, como eu consigo subir as imagens Acaba sendo mais fácil, hoje a loja é minha única fonte de renda, as vendas do WhatsApp eu acabo cadastrando como a venda do site. então aquela ferramenta foi bem legal. Então tudo que eu vendo ali no WhatsApp eu registro pelo ponto de vendas.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-3-b277cc763d",theme:"Contexto da loja e operação",quote:"O que me mata é que às vezes é um modelo que eu ainda não cadastrei no site, então eu tenho que cadastrar para depois registrar a venda. Tanto que eu tô com duas vendas de ontem que eu ainda não cadastrei. eu tenho aqui em casa para produzir, Só que é quando eu vou olhar e ainda não cadastrei no site. E aí eu fico patinando um pouco nisso. Não não financeiro cadastro essas coisas é mais comigo eu tenho a minha irmã que ela me ajuda na parte da produção assim também só da das capas as canecas e as garrafas.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-4-e93ead7f6d",theme:"Fornecedor, estoque e logística",quote:"Sou eu mesma que produzo embalo e envio e o volume também não é tanto agora com as capas como é muita coisa e ainda tem a chupi. Aí eu tenho a minha irmã que ela fica me ajudando nessa parte Mas gerenciamento, Então eu divido meu estoque com ele. ele... Às vezes ele precisa comprar, a gente faz uma compra por mês que compra em volume.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-5-1ede508e6b",theme:"Fornecedor, estoque e logística",quote:"né, que ele já compra mais 50 capas de determinado modelo, duas vezes no mês a gente faz compra pelo menos, Como eu entrei já com a operação rodando, eu ajudo mais com essa questão da reposição. umas duas vezes no mês a gente faz umas compras bem boas de modelos. meu estoque praticamente tá todo lá. Como já estamos há cinco anos nisso, até as coisas que eu tinha aqui eu acabei levando pra lá que fica mais prático pra mim na hora de produzir. Então ele faz a...",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-6-d784a976e7",theme:"Contexto da loja e operação",quote:"eu monto aqui no programa, ele faz a impressão e aí depois eu só vou pra embalar e despachar mesmo. parece que ele dá 15 dias pra gente acertar. na segunda-feira faz um pedido de plantas capas. Aí desse pedido ele dá 15 dias pra gente acertar aquele pedido. mas a cada 15 dias eu sei que eu tenho que pagar ele lá. que foi o que aconteceu semana passada, A gente fez um pedido de emergência, junto com o pedido que a gente faz na segunda-feira. acaba juntando e a gente faz no pagamento tudo junto.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-7-77446c764b",theme:"Margens, preços e PIX",quote:"não não é sempre à vista ele só dá essa flexibilidade dos 15 dias mas é sempre afetou tanto Então a gente pede mais as capas que está vendo que está acabando ou quando assim dá um boom e zero mas está rodando vendas sempre. É uma coisa que eu sinto muito que o site deu uma caída e a trope continuou. Só que o que eu gostava do site é que eu recebia mais rápido acho que eu tenho um prazo maior para receber então meu fluxo deu uma apertada mas assim é tranquilo pelo volume de vendas dá para equilibrar.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-8-49df50876b",theme:"Retenção, cobrança e controle de caixa",quote:"Eu achei melhor ficar pelo Nuvem Pago mesmo. o pessoal gosta muito de comprar pelo Pix. Então no Pix eu acho que é dois dias para cair alguma coisa assim, então acaba sendo mais rápido para receber o dinheiro do que na Shopee, porque a Shopee eu acho que espera... porque assim, eu não ativei aquele Shopee antecipa. Eu acho que ela espera o cliente receber, aí tem um tempinho lá de quando ele recebeu, aí eles liberam o dinheiro para mim.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-9-d04f93f4db",theme:"Margens, preços e PIX",quote:"assim no site como também incentivo que eu dou desconto para a pessoa comprar no PIX. Então acaba que assim eu vendo rapidinho já já entra de novo já entra o valor para mim dependente se eu enviei ou não porque no site eu coloco um prazo maior para entregar. Eu faço uma embalagem diferenciada para o site eu coloco uns brindes. Então eu tento dar um incentivo maior para o pessoal comprar comigo no site. Então por ter esse prazo também de entrega, então eu recebo sem ter enviado o produto ainda.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-10-644333c192",theme:"Crédito, empréstimo, CET e bancos",quote:"Então o meu fluxo acaba sendo mais tranquilo. Apelei para o empréstimo que estava fornecendo na Nuvemshop, porque eu quis entrar com as canecas e com as garrafas, então como as minhas vendas tinham caído muito, acabei usando para poder me ajudar na aquisição das máquinas. As canecas e as garrafas eu faço aqui. Aí já não tem nada a ver com o meu parceiro das capinhas. Assim como eu tive que investir em produto, as capinhas em si elas já estão rodando e tá mais tranquilo.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-11-4f8e0426c0",theme:"Contexto da loja e operação",quote:"Ficava um pop-up aparecendo todo dia Aí porque eu fiquei com o pé atrás um pouquinho de pedir, apesar de eu ter essa procura justamente porque a minha embalagem no site é como... muita gente compra comigo para presentear. mas elas não sabem qual que é o modelo de celular da pessoa.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-12-3caf7a8552",theme:"Crédito, empréstimo, CET e bancos",quote:"eu tenho cartão presente no site também, que eu acabo vendendo o cartãozinho, só que eu tava querendo alguma coisa que fosse, Aí por isso que surgiu a ideia das canecas, aí de tanto ter se pedido esse apelo pelo presente no final do ano, e estava aparecendo bastante e minhas vendas tinham caído eu estava querendo ter o valor para poder investir. Então se o Natal já estava aí é um pessoal que só pede muito para presente e estava focando aquele banner na minha cara.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-13-8d42202368",theme:"Crédito, empréstimo, CET e bancos",quote:"A questão da venda das canecas e das garrafas talvez até por eu ter que fazer um pouco essa migração Porque a minha ideia era a venda das canecas e das garrafas pagar esse empréstimo, e hoje ainda quem tá pagando empréstimo são as capinhas. Eu sei que dá para ampliar para mais coisas, Eu vivia fazendo simulações para ver qual que ia encaixar um pouquinho melhor. Aí teve... uma das vezes teve alguém que entrou em contato comigo para explicar... e aí eu ainda fiquei mais uma semana ali meio relutante a pedir...",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-14-c7ba15e84a",theme:"Contexto da loja e operação",quote:"Então assim... o processo em si... para fazer a solicitação foi tranquilo. foi mais eu fazendo conta e entendendo se eu ia realmente pedir ou não. A pessoa que conversou comigo explicou certinho a questão de como que é funcionar o pagamento e tudo.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-15-9238beb2c6",theme:"Crédito, empréstimo, CET e bancos",quote:"Ele falou que dava para antecipar se entrasse em contato, não tinha muitas opções quando eu fiz a solicitação, Acho que tinha para pagar em duas vezes, Em quatro eu fiquei um pouco apreensiva, porque era um valor bem alto e como as minhas vendas das capinhas tinham caído bastante, vai me enforcar ao invés de me ajudar. Então a outra opção que tinha era em seis, Então cartão eu pensei em usar só que não assim ia ficar tudo muito espalhado.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-16-ef0d06ed30",theme:"Marketplace, canais e omnicanal",quote:"Eu tentei eu quis concentrar uma coisa só e para o valor que eu precisava não há outra opção. Cheguei sim a cogitar em outros lugares. Vocês seguram o valor que eu recebi. acaba que às vezes eu tenho que apelar muito para a pessoa do WhatsApp comprar comigo no site para o valor ir se acertando. Eu não estou conseguindo cadastrar os modelos no site. E acaba querendo fechar a venda pelo WhatsApp. Então vai chegando ali na data que vocês... que eu preciso acertar, Então eu fico um pouquinho apreensiva com isso. Mas...",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-17-f20d74a35a",theme:"Marketplace, canais e omnicanal",quote:"Eu fico... A minha questão maior é assim, Aí eu juntei R$ 400 com as vendas do site e eu tenho um valor comigo. Será que... Como que ficaria para eu acertar o restante? E aí eu tenho o valor em mãos das vendas que eu fiz no WhatsApp para casar as luas, É só isso que me deixa um pouquinho desconfortável, só que eu tenho outras coisas para pagar.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-18-9556a11379",theme:"Crédito, empréstimo, CET e bancos",quote:"Apesar disso, eu tinha que pagar isso daqui agora, só que eu sei que tem venda que vai cair da Nuvemshop ainda; então, é esse emaranhado que eu preciso fazer que complica um pouco. isso pra mim na época ficou um pouquinho desconfortável. quantas coisas que eu precisava comprar. Acho que o valor total dava uns quatro e quinhentos por aí. E o restante eu acabei optando por usar esse empréstimo. se fosse um pouquinho mais espaçado, eu sei que eu posso pagar em dez vezes. mas pelo apelo eu acabei optando por usar.",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (2)-19-830f22e047",theme:"Contexto da loja e operação",quote:"eu poderia comprar um lote menor pra testar principalmente por conta das máquinas, se eu tivesse esse... Seria um fluxo de caixa mais rápido,",citedBy:"Joyce"},{id:"dovetail-transcript-2026-04-14 (3)-0-2123fdb178",theme:"Marketplace, canais e omnicanal",quote:"que eu combinava por ali e entregava pessoalmente. não preciso estar ali presencialmente para poder vender. foi por indicação de quem já é do nicho. Então eu nunca nem pensei em trocar também. eu criei meu site foi em janeiro do ano passado. também continuo trabalhando com o Marketplace, que é a minha principal fonte de renda. E o site é unicamente para expandir.",citedBy:"Douglas Eusébio"},{id:"dovetail-transcript-2026-04-14 (3)-1-310be02895",theme:"Marketplace, canais e omnicanal",quote:"toda a renda ali é reinvestida na própria loja, Tanto que eu quero expandir para uma loja física, tanto a loja física e a Nuvemshop trabalhando junto ali no site, É porque eu trabalho com dois tipos de públicos, eu consigo levar eles para o meu WhatsApp pessoal mesmo. E aí, esse público é para o outro WhatsApp, Eu trabalho com contador e com CNPJ. Eu trabalho na modalidade de dropshipping. eu trabalhava com dropshipping internacional.",citedBy:"Douglas Eusébio"},{id:"dovetail-transcript-2026-04-14 (3)-2-e90530c84a",theme:"Fornecedor, estoque e logística",quote:"passava para o fornecedor e o fornecedor ficava responsável pela entrega do produto para o cliente. eu já conheci outros fornecedores brasileiros, Eu já fiz uma parceria com o fornecedor que eu consigo pegar no valor de atacado mesmo pegando uma peça, eu já pego no atacado de qualquer forma. O único combinado que eu tenho com o fornecedor é te pegar uma peça, eu já pego ali seis peças em torno disso. Mas se for menos peças que eu precisar pegar, eu já consigo sacar para poder fazer o pagamento.",citedBy:"Douglas Eusébio"},{id:"dovetail-transcript-2026-04-14 (3)-3-39ce76ba7b",theme:"Crédito, empréstimo, CET e bancos",quote:"para também não ficar dependendo do valor do cliente. Eu fechei com esses fornecedores muito recentemente. E eu também não acho que seja tão interessante fazer isso. Eu não fico com aquela pendência com ele. aí nesse caso eu já utilizei o cartão, Utilizei um cartão de crédito para poder pegar as peças. é porque eu tenho limite no cartão corporativo ali e aí eu consigo também, mas é extremamente raro usar o cartão quando é o cliente fez o pagamento no cartão.",citedBy:"Douglas Eusébio"},{id:"dovetail-transcript-2026-04-14 (3)-4-9e9ce9cc00",theme:"Crédito, empréstimo, CET e bancos",quote:"Foram muitos clientes que fizeram o pagamento no cartão e aí o dinheiro fica retido ali pelo menos dois dias para poder liberar e aí eu uso o cartão. Mas é extremamente raro porque eu tenho um caixa saudável para poder segurar, Eu não olhei por conta que eu acho que só é válido se for para mim escalar de uma forma grande. Se for para mim pegar pouco crédito para poder comprar algumas peças eu acho que não compensa. Agora se for para mim escalar de fato é passar para a loja física como eu quero fazer.",citedBy:"Douglas Eusébio"},{id:"dovetail-transcript-2026-04-14 (3)-5-feabeb4372",theme:"Crédito, empréstimo, CET e bancos",quote:"Eu já estou juntando o valor para poder fazer. Até porque eu não gosto muito de me endividar. mas eu não gosto muito de endividar. mas eu ainda prefiro levantar um bom valor e ter que utilizar pouco crédito. Eu acho que talvez se fosse um pouco mais automático o processo de mostrar as opções. provavelmente tem alguma análise ali, mas se fosse um pouco mais rápido para poder exibir.",citedBy:"Douglas Eusébio"},{id:"dovetail-transcript-2026-04-14 (3)-6-8099a22c6a",theme:"Contexto da loja e operação",quote:"com certeza eu teria ido um pouco mais adiante, aí ele vai mandar para o meu e-mail, a vida de empreendedor é extremamente corrida, aí tem que ir lá ver no e-mail e tal, eu acho que se interessa talvez um pouco.",citedBy:"Douglas Eusébio"},{id:"dovetail-transcript-2026-04-14 (3)-7-f6a927fbc5",theme:"Crédito, empréstimo, CET e bancos",quote:"acho que foi mês passado ou retrasado, mas se você clica na opção de simular, ele não mostra ali as opções na tela, é que a gente vai entrar em contato e tudo mais e se ele enviar no e-mail ele não aparece ali na dashboard né as opções pelo menos para mim não apareceu quando eu fiz ele enviar no e-mail o valor que mostrou na minha tela foi de R$ 9.000 Não me interessou tanto Porque com R$ 9.000 eu ainda não consigo expandir para uma loja física Ainda teria que contribuir com um pouco mais Então não me chamou tanta atenção, Provavelmente ele libera ali um valor para cada pessoa, dependendo Pelo menos esse valor que liberou ali não me chama tanta seria o valor e juros também é interessante, Mas acredito que em maior quantidade de parcelas, um bom valor e em grande quantidade de parcelas.",citedBy:"Douglas Eusébio"},{id:"dovetail-transcript-2026-04-14 (3)-8-88872f1620",theme:"Crédito, empréstimo, CET e bancos",quote:"Eu teria que parar para pensar em algum cenário, Seria um empréstimo para pagar em cinco dias? Porque eu tenho esse caixa bem saudável, bem saudável mesmo para poder fazer o giro ali, depois que teve essa atualização na Nuvemshop e passou o cartão para dois dias, Aí ele matou isso que você está falando entendeu. Porque se fosse 15 dias ia valer muito mais a pena como estava 15 e 30.",citedBy:"Douglas Eusébio"},{id:"dovetail-transcript-2026-04-14 (3)-9-5f587055e8",theme:"Plataforma, Nuvemshop e integrações",quote:"Mas como ver essa atualização de dois dias, mesmo com um juro um pouco maior, ainda compensa mais esperar esses dois dias, desde que tenha um caixa saudável, entendeu? Porque às vezes eu faço um planejamento de receber o valor e tal, se ele tirar todo o valor do saldo que eu tenho para receber, não tem muito a ver com isso que a gente tá conversando, só um pouco que eu acho que dá uma bagunçada: o valor que vem pra mim é com frete. E eu acho que poderia ter uma opção na Nuvemshop pra já descontar.",citedBy:"Douglas Eusébio"},{id:"dovetail-transcript-2026-04-14 (3)-10-dddb5bdab3",theme:"Margens, preços e PIX",quote:"Porque, vamos supor que o cliente simulou e o frete para ele deu 15 reais. Eu recebo esses 15 reais, porém na hora de eu pagar o frete e pagar o envio eu vou ter que pagar os 15 reais mais a taxa do cartão ou a taxa do Pix. Ou seja, acaba que eu tenho que colocar um adicional na hora. Eu teria que colocar um adicional de R$ 2,00 para poder ter uma margem segura. E eu acho que poderia ter uma opção na Nuvemshop, já descontando. Poderia vir para mim só os R$ 200,00.",citedBy:"Douglas Eusébio"},{id:"dovetail-transcript-2026-04-14 (3)-11-d504c85194",theme:"Retenção, cobrança e controle de caixa",quote:"Ou ele já vai como saldo direto lá para o Nuvem Pago. ao invés de eu precisar adicionar o saldo,",citedBy:"Douglas Eusébio"},{id:"dovetail-transcript-2026-04-14 (4)-0-e9368ccb99",theme:"Crédito, empréstimo, CET e bancos",quote:"Há algum áudio aqui falando que a chamada estava sendo gravada. Eu acredito que comecei há oito anos, já fui da Atrey também e resolvi ficar na Nuvemshop, que acredito que está sendo a melhor até o momento. De vez em quando entram em contato no WhatsApp. O pagamento eu gero através do site. Geralmente, quando ela quer comprar no WhatsApp, eu mando o site e ela printa os produtos e compra no WhatsApp.",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (4)-1-3106116cc7",theme:"Fornecedor, estoque e logística",quote:"Tem gente que tem um pouco de dificuldade de preencher as informações no site, Tem algumas pessoas que têm dificuldade de comprar, Mas eu acredito que é mais falta de conhecimento da pessoa mesmo. Se eu criar um pedido é cobrado uma taxa. Só uma observação o meu cachorro vai latir porque tem gente chamando outra pessoa. A maioria dos meus fornecedores são daqui. eu faço o estoque e compro em São Paulo. Geralmente eu vou na cidade duas vezes por semana.",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (4)-2-accd45fea2",theme:"Margens, preços e PIX",quote:"Eu só compro o estoque dos materiais que eu não consigo produzir, eu vou lá e compro o material e faço. Eu só compro as coisas à vista mesmo. Na internet é mais PIX porque dá desconto e presencialmente é mais no débito. Para incentivar eles a dar desconto no PIX. Porque eles estão perdendo uma taxinha no débito. Não precisar acredito que no começo desse novo governo dê uma apertada Eu tive que recorrer aos outros meios, caiu de R$19.000 para R$3.000,00, R$4.000,00.",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (4)-3-9916733818",theme:"Crédito, empréstimo, CET e bancos",quote:"Aí eu tive que recorrer aos outros meses para pagar, Estou conseguindo me recuperar agora, estou conseguindo me estabilizar em R$10.000,00, mas não recuperei ainda os R$20.000,00 que eu fazia antes. Acredito que foi 2,5% a 3%. Entendeu? acredito que não cheguei a comparar. Mas eu já fiz uma pesquisa e vi que a taxa estava boa, Dificilmente alguém dá um empréstimo no 2,5 hoje em dia. Mas eu vi que é uma taxa bem um pouco elevada. Estavam umas parcelas de mil e pouco.",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (4)-4-383518b92c",theme:"Crédito, empréstimo, CET e bancos",quote:"O meu interesse de pegar esse empréstimo da Nuvemshop era para fazer uma importação. Eu preciso de no mínimo 8 a 10 mil reais. A importação para chegar demora uns dois meses. eu ia ter que pagar uma parcela antes da importação chegar. Eu não fiz esse cálculo de quanto tempo eu iria precisar. Mas o que barrou foi a taxa e o prazo. porque ia demorar a importação para chegar, eu ia ter que ter o capital antes de vender, Aí eu deduzi que não valia a pena no momento, eu fazer essa importação sem pegar empréstimo.",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (4)-5-4947750c00",theme:"Crédito, empréstimo, CET e bancos",quote:"Eu conversei com um rapaz no WhatsApp, Mas acredito que não é da equipe de vocês, Acredito que foi ele que entrou em contato. Eu não decidi contratar por conta do prazo, e do contrato ali que eu achei um pouco, Não sei se seria uma forma adequada, Mas é uma forma que dá segurança para a empresa que está oferecendo o empréstimo. Porque não dá possibilidade de dar um bloqueio. Todo bloqueio acredito que seja abusivo. Mas ele deixa claro antes de contratar.",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (4)-6-88b8343b8f",theme:"Crédito, empréstimo, CET e bancos",quote:"Eu acredito que o que me preocupou também foi o fato de que ele começa a bloquear um mês antes. Já fica um mês ali antes de bloquear. Ele já perde um mês de prazo para pagar. Ele já bloqueia um mês antes para pagar a parcela futura. No caso está praticamente obrigando a gente a pagar um mês antes a fatura. A gente poderia estar com esse dinheiro para outros planos outras coisas mas está ali bloqueado para pagar uma fatura do mês que vem. A pessoa tem que ter muito controle para conseguir pagar.",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (4)-7-d2ff9b1fb7",theme:"Crédito, empréstimo, CET e bancos",quote:"Eu não pensei pega o desprevenido e tal. a pessoa não vai conseguir sacar para pagar outras contas, como compro material assim que vendo, não ia conseguir sacar o dinheiro para comprar material, que ia estar preso para pagar o empréstimo. Aí eu não ia conseguir enviar e tem que ter muito controle para pegar esse empréstimo. Eu acredito que o máximo foi seis vezes. no decorrer tirou todas as dúvidas que eu tive.",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (4)-8-08d938616f",theme:"Crédito, empréstimo, CET e bancos",quote:"Porque eu preciso de tempo para comprar o material e vender para ter o retorno para pagar o empréstimo, Normalmente eu não tenho necessidade. decidi qualquer tipo de desse crédito. Teria necessidade de um crédito com prazo, Com crédito de curto prazo eu não tenho necessidade, Se eu pegasse um valor um pouco elevado, Que eu não tenho hoje uma embalagem mais personalizada. acredito que 15% eu investiria nisso. Eu tenho alguns pontos bem tranquilos. É cobrado taxa para fazer a venda no cartão.",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (4)-9-db20df6d4b",theme:"Crédito, empréstimo, CET e bancos",quote:"Tem a questão do carrinho abandonado, que eu acho que vocês capturam muito pouco, mas acredito que vocês devem ter algum motivo. Tem a questão da informação que aparece quando entra no site, Tem uma informação ali que a maioria dos meus clientes não entendem como tirar aquilo, E os meus clientes navegam por aquilo e acaba atrapalhando um pouco no celular. Acaba ficando em cima das informações. Alguns segundos e aquela informação sai automaticamente.",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (4)-10-7916e84fd0",theme:"Fornecedor, estoque e logística",quote:"Porque ele não consegue fechar ou não entende que aquilo pode fechar. E tem uma questão também da Nuvem Envio, que eu acho que tem muitas etapas para fazer o pagamento. Se tivesse a opção de eu adicionar no carrinho os envios e fazer um pagamento único, porque eu não sei qual vai ser o valor final. E eu não sei também se pode tirar o saldo, Eu uso o Nuvem Envio e uso a log nativa.",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (4)-11-599cfa34bb",theme:"Crédito, empréstimo, CET e bancos",quote:"Às vezes está mais barato na Nuvem Envio, Se tivesse uma opção de eu gerar os envios e botar no carrinho e pagar tudo de uma vez, como acontece em outras ferramentas. Acredito que na melhor envio acontece. Todo pedido que eu vou gerar uma etiqueta, Eu tenho que clicar em comprar etiqueta, Acredito que são essas questões que eu tinha para falar, A minha área financeira ou do Nuvem Pago? Seria interessante ser tipo um... Como é que se fala? Que eu pudesse fazer PIX e pudesse fazer pagamento diretamente do Nuvem Pago.",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (4)-12-4422a79f4d",theme:"Crédito, empréstimo, CET e bancos",quote:"Essa questão de transferir saldo acaba demorando um pouco. Tem que transformar o saldo do Nuvem Pago no banco digital para poder fazer PIX, Mas eu acredito que seria mais interessante para qualquer lojista. Eu me recordo que eu li esse formação em algum lugar,",citedBy:"Mayke Gomes"},{id:"dovetail-transcript-2026-04-14 (5)-0-6679221350",theme:"Tráfego pago, mídia e aquisição",quote:"Nós estávamos pensando em montar uma loja online, E aí a gente não tinha noção nenhuma de nada Viu o anúncio de algumas lojas que vendiam roupa pela internet E a gente pensou, Também tinha duas crianças pequenas, queria ficar em casa Seria uma coisa que conseguia assimilar bem, né? E aí a gente pesquisando apareceu o anúncio da Nuvemshop E, Tem os artigos lá dentro da plataforma, falando o que a gente tem que fazer. Em três dias a gente já colocou um anúncio pra rodar. porque na época o orgânico era muito bom.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-1-d903874f20",theme:"Tráfego pago, mídia e aquisição",quote:"O orgânico das redes sociais você tem que impulsionar, ninguém vê nada do que você colocou lá. a gente foi montando e eu sou suspeita, acho que o atendimento deles são fora de sério A gente usa transportadora, a gente manda e-mail pra ele No outro dia, o problema já é solucionado Falo assim, de entrega, né, que às vezes a Jadlog ela entrega um pouquinho mais atrasado do que ela deveria entregar Ou às vezes ela não tá achando o comprador, né E a gente manda pra eles logo no outro dia, ou no mesmo dia A maioria das vezes respondem no mesmo dia E eles já dão um C-SPORT pra gente A gente vê lá no rastreio que já foi atualizado, da mensalidade Não troco de jeito nenhum, pode vir outras plataformas Entra no TikTok, veja outras lojistas falando que trocou Eu não me arrisco, não tem o que questionar Eu sei que tem pacotes mais caros lá, Aí vai dar necessidade na loja Acho que o valor básico pra mim já me atende muito bem, a gente só trabalha com moda feminina, a gente já trabalha com moda masculina Acho que até é um público muito bom, acho que os homens são menos exigentes, menos complicados para vender pra mulheres Mulher marca a barriga, tem meu marido que é meu sócio Mas eu por estar à frente, a minha família teve loja de tecido e armarinho.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-2-b3b8070d7a",theme:"Crédito, empréstimo, CET e bancos",quote:"Eu já conheço todos os tipos de tecido. o público tem vontade de voltar com a moda masculina. Acredito que esse ano não vai ser um ano muito fácil, muito favorável E acredito até que as lojas que vendem bastante vão vender um pouco menos E as que não vendem, o online é o caminho Se você quiser continuar nesse meio aí, você tem que estar no online As lojas físicas estão fechando E o online, eu acho que a gente começou super bem Desde quando a gente começou, a gente já montou site de cara Eu vejo muitas pessoas falando assim, você tem que esperar Eu já não acho, eu acho que o site ele passa profissionalismo, ele dá uma autoridade para sua marca Tem muitas pessoas que já compram direto no site.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-3-f03bfe7bfb",theme:"Tráfego pago, mídia e aquisição",quote:"A gente tem muitos clientes que compram no WhatsApp. a gente tem que ter um atendimento já automático, Eles também me chamaram pra participar Participei, a nossa loja foi loja teste Aí eu falei pra eles, não Você tinha a opção de cobrar uma taxinha, emitir nota fiscal sem estar pagando nada E a nota fiscal deles é muito rápida, é coisas para facilitar a vida da gente Porque a gente não entende muito sobre regras, né, mas não é igual uma contabilidade Então, a gente é vendedor Se chamar pelo direito do Instagram, tá perfeito Só quer dizer que o nosso foco, Não que eu não quero ter contato com o cliente, a gente tem que entender como está o mercado, eu falo assim que lá ele já tem tudo lá na mão dele, a gente fala detalhadamente o tecido, a gente tem fotos de todos os lados da peça.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-4-db6a125522",theme:"Contexto da loja e operação",quote:"Mas a gente tem um monte de depoimento de cliente usando as roupas Às vezes a pessoa fala assim, o vestido cliente mais vende lá A gente tem 25 depoimentos com foto de cliente usando Então no cliente dá pra você ter uma noção de como vai ficar mais ou menos o seu corpo São fotos reais, eu gosto de comprar meu site Eu não gosto de ficar mandando mensagem, ou às vezes ele não tem aquele tempo, aquela atenção que a gente queria ter, Acho que é o meu sonho que fosse sempre pelo site.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-5-95ff34cb09",theme:"Contexto da loja e operação",quote:"a gente tá sempre cada vez melhorando o site, se a gente recebe um questionamento do cliente, tentar zerar o máximo de dúvidas pra ele ir lá e sentir toda a segurança e comprar. que a gente já teve outros comércios e eles estão com a gente desde o começo, toda orientação também que a gente tem dúvida, que às vezes vai mudar alguma coisa, igual declaração de imposto de renda, a gente entra em contato com eles também e vai alinhando.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-6-80d31aabb5",theme:"Contexto da loja e operação",quote:"A gente já tem os produtos que já vende naturalmente, que a gente já sabe que todo dia vende, E a gente vai sempre atrás de novidades. O nosso público é um público que ele já compra a roupa para alguma ocasião, E a maioria entre em contato com a gente é porque tem um casamento, um churrasco Sempre uma ocasião específica Então assim, roupa básica pra gente entender o que a gente não consegue vender A gente já trabalhou com muita roupa jeans, camiseta básica E não é uma coisa que sai muito pra gente, no nosso caso O que a gente mais vende é vestido E sempre vestido pra alguma ocasião, tipo uma festa E as pessoas procuram a gente, ela quer um vestido pra uma festa Mas ela tem um vestido que ela consegue orar depois Ela não quer comprar um vestido que depois ela tem que deixar ele guardado no guarda-roupa E, senão ficaria muito batido Ela quer um vestido que ela consegue usar hoje pra ir num casamento, uma convidada Aí vamos supor que daqui mês que vem ela joga uma jaquetinha em cima e uma bota e ela consegue sair com ele à noite Então peças versáteis, então a gente pegou que as pessoas que procuram a gente querem isso a gente tá sempre nessa pegada de procurar vestidos, Tem gente que já gosta com aquela fenda bem aberta, A gente tem que atender todos os públicos.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-7-4b1521e3ce",theme:"Tráfego pago, mídia e aquisição",quote:"A gente tem que ter pra todos os gostos, A gente já tem as nossas peças chaves, E a gente percebe que quando o estoque, a grade está quebrada Isso impacta no nosso tráfego pago, geralmente a cor que não tem é a cor que elas querem Geralmente o tamanho que não tem é o tamanho que elas querem É assim, E sempre buscando novidade A gente tem um leque muito grande? Porque eu entendi também que eu prefiro profundidade, o cliente também fica meio na dúvida.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-8-bf8e1cc6b6",theme:"Fornecedor, estoque e logística",quote:"É tanta opção que eu tenho que ele já fica confuso, eu prefiro trabalhar com mais profundidade, o nosso estoque é 100% pago Quando a gente compra mesmo, pede desconto Ou a gente ganha o FRED pra gente ganhar uma vantagem Porque quanto mais benefícios na compra, a gente consegue também repassar isso pro cliente Bom, uma vez por mês a gente faz parte grátis pra todo o Brasil A gente melhorou muito que quando a gente começou a gente enviava em saquinho comum Hoje a gente faz um boxzinho, a gente manda mimo Todas essas compras vai com mimo, a gente tem tag da loja personalizada Porque a gente sente que hoje o cliente tá cada vez mais exigente, sabe? Ele não quer mais aquele saquinho preto que chega lá na tua casa e que você rasa e joga no lixo.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-9-11e9582831",theme:"Tráfego pago, mídia e aquisição",quote:"Isso não existe no nosso meio da moda feminina, marcha duas vezes por semana com as novidades ou reposição que chegou E a gente tem muitos casos de pessoa voltar e comprar o mesmo vestido em outra cor A gente acha isso engraçado, a gente fala assim, não precisa trazer novidade não Porque o cliente volta e compra a mesma cor, tem um vestido que a gente vende muito que é o Glenda comprou um xícara em dezembro do ano passado Quando foi dezembro desse ano, tudo pelo direito do Instagram Depois ela mandou mensagem, ela comprou quatro vezes o mesmo modelo, Eu já tive cliente que já comprou sete cores, E ela foi entregar na casa da mãe dela aqui no Rio de Janeiro.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-10-d314d3f098",theme:"Crédito, empréstimo, CET e bancos",quote:"Eu até comentei com o meu marido e ele falou assim, uma super comprou o preto basiquinho, a gente não tem esse negócio de promissória, A gente gosta de ter um trabalho mais sólido, Eu sei que a mercadoria minha tá aqui, mas acho que quem fabrica aí pode Aí com certeza, ela deve ter essa negociação que você falou, eu vi que a Nuvemshop tem uma linha de crédito lá hoje, A gente tenta pegar 100% do nosso dinheiro da loja e a gente sempre reinvestir A gente pensa assim, eu já trabalhei fora e já pus muito dinheiro dentro da loja Meu marido hoje em dia também trabalha fora Ele trabalha fora, Então a gente tenta pensar sempre acima, porque ele paga todos os custos da casa e o da loja sempre volta para a loja.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-11-91f84b4cfd",theme:"Tráfego pago, mídia e aquisição",quote:"E a gente entende que é uma empresa, se a gente ficar tirando o dinheiro dela, mas assim a gente prefere sempre reinvestir nela, a gente entende que mercadoria é dinheiro, a partir do momento que eu tenho um estoque bom e consolidado, lógico que às vezes a gente queria comprar mais, porque a gente tem que deixar margem para marketing, a gente tem que ter aquele dinheiro de emergência, mas eu aprendi ao longo do tempo que não é o certo, a gente já sabe mais ou menos quando a gente tem que comprar, né? Então a gente vai trabalhando em cima disso.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-12-be3c1a22b9",theme:"Fornecedor, estoque e logística",quote:"eu peço a reposição e vou trazendo um pouquinho de novidade Porque eu não sei se essa novidade vai ser bem aceita ou não Então eu não fico com peça escalhada E como a gente vende marketplace também O engraçado é isso, que as minhas peças escalhadas no marketplace vende tudo É tão bom que eu falo assim, se eu pudesse recomendar para o logista eu não coloco no Marketplace Eu já deixo no site ou com a gente, porque elas já vão vender naturalmente Agora aquelas que não teve boa saída, eu coloco no Marketplace E se eu precisar, eu dou um desconto mais agressivo Nem que eu recuperar só o valor da peça, pra mim é lucro Porque eu com esse valor da peça, ele ajuda muito nessa parte Porque lá não tem esse negócio de, a gente trabalha muito a rede social Tráfico nos produtos que vende mais.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-13-54afde0632",theme:"Contexto da loja e operação",quote:"Esses produtos que eu vendo muito na nossa marca, Então eu consigo vender esses produtos que estão parados. praticamente já não vendeu mais nada, E depende disso pra gente, a gente vê como uma vitrine, né? a gente posta muito vídeo no YouTube, muitas pessoas vêm até nós por vídeo do YouTube, todos os lugares que a gente puder tá, porque a gente já gasta muito com tráfico. A gente vai estar sempre aparecendo no ordônico.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-14-b08a4891fc",theme:"Crédito, empréstimo, CET e bancos",quote:"mas eu achei que os juros estavam um pouquinho bem salgados, Porque se eu tenho um estoque bom e eu tenho dinheiro pra mim girar, não seria viável pra mim Mas nada impede, se a pessoa acha que ela tá precisando daquele dinheiro, que o dinheiro ela vai conseguir ajudar no negócio dela e que ela consegue embutir esse juro naquele lucro, nada contra Nós já pegamos dinheiro no começo a gente já investiu muito dinheiro na nossa loja, porque como o meu marido já trabalhou muito fora, no começo a gente trabalhava muito fora, a gente não foi assim fazendo as secas, Então a gente pegava certo trabalhista, entrava o dinheiro e a mercadoria Que eu precise dela pra eu ir trabalhar Assim, também no começo a gente começou fazendo o...",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-15-54dfe80280",theme:"Modelo de negócio (dropshipping, sob demanda, artesanal)",quote:"Como é que fala? Esqueci o nome Quando você não tem a mercadoria, pronto-entrega A Noventchal também faz dropship, No começo a gente começou com dropship também Pra gente sentir se ia dar certo ou não E deu muito certo, vamos ter pronta-entrega Porque as pessoas querem experiência de compra A gente não tem o controle de como vai chegar o cliente, e a gente tem que trabalhar mais rápido, porque a maioria que a gente vende é sedex.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-16-5f3e4a9e68",theme:"Crédito, empréstimo, CET e bancos",quote:"Então a gente começou a ter o nosso toque pronto, E quem começa a empreender é um caminho sem volta. Mas que a gente não pode levar aquilo por via de regra, que graças a Deus são exceções Exceções muito grandes, é um caminho sem volta Eu não quero trabalhar pra ninguém mais, eu quero trabalhar por conta própria, E a gente vai continuar nessa linha e tá no Venshop aí que vem a mais 10 anos, mas eu acredito que a gente deve ter pegado com banco, porque eu acho que descontava a folha de pagamento, Pra gente começar um estoque inicial, a gente foi colocando tudo dentro da loja.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-17-e28fd9120a",theme:"Crédito, empréstimo, CET e bancos",quote:"empréstimos descontados da folha de trabalho. já me deu um aporte financeiro bom pra mim também investir na empresa. e tudo que a gente vai reinvestindo, Eu entendo que isso é o mais importante. Às vezes a gente corta muitas coisas que a gente queria fazer, porque já no começo a gente teve um pouco daquela ilusão de ganhar muito dinheiro e achar que você tá rico. porque no outro dia tem que pegar esse dinheiro e comprar de novo. Hoje a gente tem a cabeça muito no chão.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-18-5aa0d2e985",theme:"Crédito, empréstimo, CET e bancos",quote:"E a gente percebe que isso daí faz você quebrar. Porque se você não pensar que aquele dinheiro não é seu, você tem que pensar que você é um funcionário. Você tem que tirar o teu pró-labore. O resto tem que voltar pra tua empresa. a gente hoje não faz mais empréstimo, a gente pega uma promoção muito boa aí, Esse desconto que eu tô ganhando do meu revendedor compensa esse juro que eu vou pagar.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-19-7f4a69492f",theme:"Crédito, empréstimo, CET e bancos",quote:"eu achei um pouco o juro meio agressivo, a Nubank também tem opção de empréstimo, né? E a gente já cotou lá uma vez e o juro é bem menor. Às vezes é uma coisa também que eles tendem a melhorar, mas se estiver bem fora da realidade comparado a outras financeiras, os juros da Nuvemshop estão bem agressivos. Aí ele falou que se perde da Nubank, se a gente quiser a gente usa. A gente tem liberado até 50 mil reais, então não compensa no momento, certo? Todos os lojistas também vão dar esse feedback pra eles.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-20-41609d1673",theme:"Crédito, empréstimo, CET e bancos",quote:"Porque a gente que tá assim no meio, no momento eu achei assim que pra gente tá bem salgados os valores que estão lá, né? Ou às vezes tem lojas grandes que às vezes eles fazem uns valores melhores, uma vez a gente vende do Mercado Livre também, E lá no Mercado Pago eles colocam uma opção assim, eles vão abatendo o que a gente pega lá nas vendas. eles liberavam um crédito pra gente, eles iam perdendo o dinheiro das vendas. E também não era um juro salgado não, eu sei que lá no mercado pago tem essa opção lá.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-21-d0f75a71cc",theme:"Plataforma, Nuvemshop e integrações",quote:"que eu tô achando assim Às vezes não sei a financeira que eles estão usando, né Se é deles mesmo ou se é da Pagar.me que eles trabalham, né Precisa dar uma revista nisso, né Perfeito E que eu olhei lá e pensei assim Você tem 30 dias para começar a descontar Aí eu acho que vai descontando também, Por isso que também a gente não teve esse interesse, Todas as novidades da Nuvemshop, igual chegou ontem que eu entrei lá, parece que a gente queria participar da pesquisa, a gente sempre participa de tudo da Nuvemshop, Então sou suspeita de falar E quando alguém falar que tá saindo da plataforma pra ir pra outra Eu fico me questionando se a pessoa é louca Eu acho que ela é louca, eu já olhei o site de outras pessoas, Faço uma impressão assim de amadora até.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-22-fc7e586d8c",theme:"Plataforma, Nuvemshop e integrações",quote:"às vezes alguma coisa que elas não gostaram da plataforma, é só entrar em contato com a equipe, Toda semana eu chego e-mail pra eles. E às vezes eles mandam avaliação pra gente avaliar, você me coloca alguma coisinha assim, você não consegue ter aquela visão assim, se fosse descontar nas vendas que vai cair, teria que ter um relatório bem detalhadinho lá para a gente não ter confusão Porque, aconteceu uma vez um caso da gente ter um chargeback Isso foi a única vez que aconteceu na Nuvemshop que eu fiquei meio chateada com eles E eu mandei o e-mail e falei mesmo pra eles que eu não gostei Mas eles alegam que é o banco, Uma cliente, ela entrou em contato pelo WhatsApp e ela perguntou muito detalhadamente das peças, tal, tal, tal Aí aquele caso que eu te falei, ela comprou três peças do mesmo macaquinho, só mudou a cor Só que eu achei esquisito, porque geralmente as pessoas não fazem Isso não é comprar três cores diferentes da mesma peça de cara Mesmo essas pessoas que compram hoje esse vestido Glenda que eu te falei Elas compram uma cor, se elas gostarem elas vêm comprar outra Às vezes ela compra duas peças, A gente enviou pra ela o mesmo padrão que a gente trabalha Caixinha personalizada, mandamos um gloss Porque acima de 240 reais, 350 reais no site Você ganha um gloss, a gente manda aquele negócio de registrado, que a pessoa tem que se dar com o documento, Ela colocou que...",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-23-5268f21d4a",theme:"Plataforma, Nuvemshop e integrações",quote:"Não é que ela colocou que ela não recebeu, desacordo comercial Como se ela quisesse devolver e a gente não quisesse aceitar a devolução dela Só que em nenhum momento ela entrou em contato com a gente Em nenhum momento ela falou nada Aí a gente respondeu, Falou que ela tava agindo de má-fé, que ela tinha entrado em contato com a gente na plataforma.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-24-af780cc28c",theme:"Crédito, empréstimo, CET e bancos",quote:"Ela tirou todas as dúvidas, só que ela comprou três peças do mesmo modelo E ela não tinha devolvido as peças pra gente, O banco extornou o dinheiro pra ela, Estornou de cara o dinheiro pra ela, eu nunca vi isso em 10 anos de loja Porque eu acho assim, mas aí o banco tem que fazer ela devolver a mercadoria então Aí quando ela provar que ela devolveu pra gente, eles estornaram o dinheiro Aí a Nuvemshop tirou o dinheiro da nossa conta, e aí ela agiu de mão com a gente porque ela parcelou em sete vezes, mas sete vezes cobra um juro absurdo.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-25-07f58e65bd",theme:"Crédito, empréstimo, CET e bancos",quote:"eu já achei muito esquisito na hora que ela fez isso, mas como eu já mandei carta registrada, não esqueci o nome do negócio que a gente manda para a pessoa, porque a gente usa isso na contestação, né? descontou o juro dos parcelamentos e descontou mais uma taxa, ela disse que nós levamos um prejuízo de 900 reais, nós levamos quase mil reais de prejuízo.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-26-ddad106bd0",theme:"Crédito, empréstimo, CET e bancos",quote:"Quando você sente que é uma coisa diferente do padrão A gente já manda com esse seguro, só tem que assinar A gente mandou tudo para evitar a contestação A gente enviou os prints do WhatsApp dela A gente enviou essa carta do Correio com as assinaturas que receberam tudo Mesmo assim, ela não respondia a gente no WhatsApp E eu falando que eu não fui na Nuvemshop, né? E eles alegavam que eles não conseguiam fazer nada Porque o banco, o cartão de crédito passou por cima deles Foi lá e já estornou o dinheiro pra ela E aí descontou tudo da gente, descontou até...",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-27-cab8cf328d",theme:"Crédito, empréstimo, CET e bancos",quote:"Só que isso daí que eu achei esquisito, sabe? De descontar da gente os juros do parcelamento Que ela fez, E esses valores eu não conseguia ver no extrato detalhado lá da conciliação. Eu tive que abrir um chamado para eles me mandar essa tabela Aí nessa tabela mostrava o valor da compra, o valor que foi descontado Você entendeu? Então isso aí tem que ter bem detalhadamente no site Eu posso até simular lá, fazer um financiamento lá Que vai ser descontado nas vendas, que eu possa somar e ver que realmente foi dedicado o valor que eu contratei.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-28-0ff445ecd2",theme:"Fornecedor, estoque e logística",quote:"essa pessoa nos bloqueou no WhatsApp, aí eu tive que fazer uma notificação judicial, E falando pra ela que caso ela não devolva... E mandou uma logística reversa, eu falei Ou você faz a devolução da mercadoria ou você paga o boleto que você dá com as peças Porque senão a gente vai protestar em cartório e negativar teu nome Ué, provado a mais bem que ela tava agindo de má fé Ela bloqueou a gente, ela desbloqueou a gente no WhatsApp E já respondeu toda ofendida, que olha o jeito que a gente tava conversando com ela E eu desconversei, mais você faz provas contra você mesma, que ela tinha o direito de não verificar as peças, só devolver isso pra gente E aí eu falei assim, e a gente pede pra gente enviar certinho pro lacre da loja, que a gente não pode aceitar sem o lacre, porque quer dizer que a peça foi usada, a gente não pode vender pra outra pessoa A outra pessoa que vai comprar, ela tem direito de estar pagando uma peça nova, E a gente pediu pra ela devolver o mimo, aí ela falou que não tinha mimo nenhum.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-29-0a1ba34ea3",theme:"Contexto da loja e operação",quote:"Como que ela não tinha visto o gloss, olha o jeito que a gente teve que agir, Eu não tinha pegado isso da minha vida, Só que se a gente não fizesse assim, E a gente teve que absorver esse prejuízo. Na prática, você não podia fazer nada, a gente teve que absorver esse prejuízo e vida te segue.",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-30-f23c3562fa",theme:"Crédito, empréstimo, CET e bancos",quote:"Eu acho estranho o banco passar por cima da financeira, é certo descontar o valor da compra, mas primeiro espero ela devolver a mercadoria, Espera ela te mandar um comprovante que ela devolveu e aí desconta de você o valor que ela pagou Não pode descontar os juros que ela parcelou ou sei lá, ainda cobrou mais R$60,00 a mais de todo o valor Eu somei tudo e isso que eu questionava eles, se a compra dela é de R$800,00 Aí foi pra R$930,00 porque ela parcelou em 7 meses Aí esses R$130,00 a mais de juros também descontou",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (5)-31-ba4cf1004a",theme:"Crédito, empréstimo, CET e bancos",quote:"Segundo a Nuvemshop, são os custos do banco lá, nós levamos um prejuízo de uns R$ 200,00, Se eu não tivesse agido assim com ela firme,",citedBy:"Andressa Sanches"},{id:"dovetail-transcript-2026-04-14 (6)-0-1b50c5f174",theme:"Plataforma, Nuvemshop e integrações",quote:"Eu tenho uma loja de acessórios artesanais, É como é um trabalho mais artesanal como eu faço, então ele me demanda um pouco mais de tempo, então tem outras coisas para fazer além da loja. mas eu acho que a Nuvemshop me facilita nesse sentido, porque eu sou meio... A questão de aprendizado de nova plataforma pra mim é sempre um saco, aí eu... As pessoas fazem pedido na loja, esse ano vai fazer três anos em agosto. eu sempre fui dentro de plataformas. Eu comecei antes com a loja integrada.",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-1-4bdc7a29c1",theme:"Plataforma, Nuvemshop e integrações",quote:"eu tenho um conhecimento de tráfego pago, então eu preferi uma plataforma que me desse plug-ins e facilidades para conectar os... para fazer campanhas, E eu vi que a loja integrada não era tão boa nisso, a Nuvemshop me serviu um pouco mais, ela tem a experiência de montar loja, o que juntou o útil e o agradável é a Nuvemshop. mas também não me adaptei justamente porque eu gosto mais de ter esse controle e eu também tô trazendo até outro negócio que eu tenho para o Nuvemshop.",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-2-b667896cd5",theme:"Plataforma, Nuvemshop e integrações",quote:"O segundo negócio ainda é bem inicial, Eu não sei falar direito sobre a plataforma que eu tô testando, eu já abri uma conta na Nuvemshop e eu tô para testar também, minha renda divide entre esses dois um pouco, 90%, e esses 10% agora tá indo por esses printables, uma das coisas muito boas da Nuvemshop é justamente as integrações que vocês têm. apesar que eu não uso tanto o Ads do TikTok, eu acredito também que seja mais tranquilo, então eu prefiro um negócio mais rápido, que eu consiga fazer isso...",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-3-4ab8cff994",theme:"Fornecedor, estoque e logística",quote:"Eu já consigo abrir uma loja em um dia, mas é uma coisa da parte financeira. Um contador pra questões mais sérias nesse sentido. que eu trabalho com importação quase com os objetos que vem importado de fora. como eu tenho uma gama muito grande de acessórios ali dentro, então eu tô sempre repondo no Stock eu tenho que praticamente olhar todo dia, né, que me avisam normalmente quando acaba o estoque ou outro, mas tem algumas peças que eu deixo até o estoque meio reduzido para não ter problema, e aí tem o seu tempo ou tem o tempo da China, normalmente importo...",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-4-20a10ac509",theme:"Tráfego pago, mídia e aquisição",quote:"no começo do ano eu importo uma vez por mês da China, eu estava importando duas vezes em grandes quantidades. A única coisa é questão de quantidade, porque aí eu tenho descontos a mais, mas as pessoas são importadas nesse sentido. Na própria plataforma deles tem um negócio de pagar em vezes, uma venda... A vantagem do meu negócio é que o custo dos meus produtos... É muito barato. Então... Acho que um dia eu já pago uma encomenda de um mês, o que custa mais caro pra mim são campanhas.",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-5-7d6e74a969",theme:"Tráfego pago, mídia e aquisição",quote:"porque eu não tive nada nesse sentido. mas o único problema que eu tive é as pessoas que tiveram interesse no… Foi um anel especificamente. Mas nada que precisasse de um investimento grande. para o primeiro investimento em marketing, você precisa ter um investimento e um dinheiro ali para empurrar o seu negócio, não é a primeira semana que você vai fazer, Então foi um tempo ali até... Não tanto tempo, mas para fazer o negócio começar a rodar e realmente começar a ter vendas.",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-6-1d999039fb",theme:"Crédito, empréstimo, CET e bancos",quote:"realmente eu precisei de usar o cartão de crédito com mais frequência e com mais… então eu acabei utilizando ele pra... Não precisei recorrer a algum empréstimo nem nada do tipo. eu sou bem conservadora nesse sentido de crédito, porque em algum momento vai precisar alguma coisa, mas no momento eu tô tentando fazer uma coisa e pagar a outra e vendo porque seria o banco e eu sei que vocês têm também a questão de crédito ali, mas também é uma coisa que eu ainda não...",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-7-20c066a4f0",theme:"Crédito, empréstimo, CET e bancos",quote:"então eu olho para empréstimo e já fico pensando como que eu vou pagar isso. eu acho que quando vocês começaram a lançar alguns pop-ups, Mas aí eu fui lá ver e o que eu fiz foi fazer simulação. Eu acho que foi umas três vezes que eu fiz isso, foi do final do ano passado até agora que teve isso, eu acho que foi no final do ano passado, aí eu acho que a última vez que fiz foi há uns dois meses atrás, eu não coloquei o valor total que estava ali, É que paga com...",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-8-b86a322f8e",theme:"Plataforma, Nuvemshop e integrações",quote:"Ele meio que reserva uma grana do seu faturamento, e ele vai dar uma... Ele reserva, né? mas pode vir de outros lugares também, porque... Eu já tive também um caso de a plataforma falhou o pagamento, que às vezes eu gero um link na Nuvemshop; esse negócio de reservar para mim é que nem... É isso, como eu sou bem organizadinha e provavelmente muito conservadora nesse sentido, um pagamento no Pix e faça assim todo mês, eu não acho que seria um bom esquema pra mim.",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-9-f1ba6b3ce9",theme:"Crédito, empréstimo, CET e bancos",quote:"Eu acho que o número de parcelas tá bom, Às vezes é meio ruim quando você coloca 24 parcelas, o que mais realmente me incomodou foi reservar esse dinheiro. O resto eu acho que é um empréstimo normal. a questão de investimento de um produto mais premium, que era uma coisa que eu queria trazer para minha loja que é prata e pedra E isso são produtos um pouco mais caros, E aí eu queria trazer esses produtos para a minha loja um tempo, então... Mas acabei não seguindo em frente com isso.",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-10-aaec06ce24",theme:"Crédito, empréstimo, CET e bancos",quote:"com certeza é mais baixo do que o Nubank. eu comparei mais com o Nubank que eu tenho conta. outras instituições que eu sei que tem, que aí eu sei que depois de uns dias eu vou conseguir pagar essa grana. eu já fico o ano inteiro pagando o MC, o tempo para pagar a primeira parcela. Seria interessante no próximo mês ou mais 45 dias, Deixar um tempo maior para pagar a primeira parcela, porque aí você consegue organizar a sua grana, Porque se eu estourei assim e tiver grana, Porque eu não gosto de ficar com dívida.",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-11-e16eb6e9fd",theme:"Contexto da loja e operação",quote:"porque aí eu tenho mais liberdade pra pagamento se eu estourei de venda. ah, vou primeiro quitar essa dívida aqui minha e aí o resto fica livre. então é uma coisa que a gente tem que estar com perspectiva para frente, e obviamente melhorando e tentando otimizar isso, mas ele sempre vai cobrar um pouquinho mais caro da gente.",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-12-d00dec8f1f",theme:"Contexto da loja e operação",quote:"é uma vontade minha ter um produto com mais prêmios, de pouco em pouco os produtos que eu tenho que são mais baratos na loja, Mas pra isso eu tenho que ter um investimento, uma pedra natural polida também é muito cara, seria mais para investir nesses... É para investir nos dois, porque você vai ficando mais caro em material. a experiência... mais ou menos as coisas que meu marido fala de... Mas eu acho que o caminho do...",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-13-2b34b5e753",theme:"Contexto da loja e operação",quote:"a jornada, Acho que a única coisa mesmo que comanda ser reserva de dinheiro ali, não poder ter liberdade de pagamento, A maioria das coisas de vocês são bem fáceis no aplicativo. Mas eu acho que é muito específico meu.",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-14-5a37e3dd14",theme:"Contexto da loja e operação",quote:"eu não sei se vai abranger tantas pessoas, eu sei que os clientes são ansiosos, e aí eu tento deixar o mais claro possível para quando a pessoa faz a venda, tem o tempo de produção para poder colocar o correio, seria mais interessante para o meu trabalho se eu tivesse, se tivesse mais liberdade de criação de status, Ter alguma coisa a mais ali pra pessoas, seria facilitaria tanto a minha vida, que aí eu consigo adicionar um texto ali, eu consigo ver pelo Google Analytics, que ele vai lá para a página dele e vai ver o status dele.",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (6)-15-d3a791d161",theme:"Crédito, empréstimo, CET e bancos",quote:"eu acho que vocês são bem redondinhos. Às vezes o aplicativo ele falha um pouco, quando eu... Tem pessoas que fazem parcelas, o aplicativo falha um pouco quando eu vou clicar ali para ver... Ah, no site dá para fazer isso certinho, O dinheiro depois de dois... Eu sei que é sempre depois de dois dias, eu não sei se é no meu celular também, Então seria interessante dar uma olhadinha nisso. Eu não sei se é problema só meu ou se é de geral.",citedBy:"Gaby Trus"},{id:"dovetail-transcript-2026-04-14 (7)-0-d5834eee53",theme:"Margens, preços e PIX",quote:"por isso que até eu tenho uma facilidade de compor, aos poucos Hoje o meu faturamento não é grande coisa Mas assim, 12 mil por mês Eu sou uma pessoa que tá crescendo aos pouquinhos Eu gosto de, então eu tenho que sempre estar trocando o preço continuamente dos produtos, o que eu vejo que mais me atrapalha é a parte de preço em promoção, que eu vejo que eu não consigo automatizar essa parte, porque nem sempre eu dou o mesmo desconto, eu não consigo deixar o desconto salvo, até com uma sugestão que eu já tinha notado para falar com vocês, Você não tem que ficar o tempo todo, ficar lá colocando o preço manualmente.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-1-dfab67d3e3",theme:"Tráfego pago, mídia e aquisição",quote:"Outro ponto também que eu já quero adiantar também é que, toda loja que tem aquele botãozinho do sale, tem uma forma de aplicar de forma automática ali os produtos em promoção, que você tem que manualmente ficar colocando na categoria. E se tivesse uma forma de a gente clicar e já puxar de forma automática, meu foco é mais meta ads que pegam Instagram e Facebook, é um público que ainda não tá tão no TikTok.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-2-2dce0712b2",theme:"Tráfego pago, mídia e aquisição",quote:"Eu já testei até outras plataformas TikTok, eu vi que não tem muito retorno porque o meu público-alvo tá mais Instagram, Então eu foco neles e rodo o anúncio. eu tô crescendo e eu faço no paralelo, Então eu cuido da loja e também tenho fé que faço frilas, assim...",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-3-d451155a6a",theme:"Tráfego pago, mídia e aquisição",quote:"Eu vi que tem aplicativos que podem me ajudar, né? Porque eu fiz meu RP com meta-eds, Eu só entro com as vendas e ele calcula tudo automático, Inclusive eu tô até vendo pra mim desenvolver o meu próprio, né? Eu já tô vendo com o IA pra entrar na parte de programação Porque eu não encontrei um que eu consigo já...",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-4-2e6a577a35",theme:"Tráfego pago, mídia e aquisição",quote:"É que eu controlo tudo, Eu sou uma pessoa bem detalhista Eu faço todo o meu custo de produto Para calcular a margem de lucro eu abato embalagens, E eu não compro um ARP que possa tirar tudo e eu junto também com o Metaeds, né? Porque eu gasto tanto por anúncio e eu recebo tanto. Quanto fica no meu caixa de forma automática diariamente? Então eu preferi montar esse sistema que eu só...",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-5-40fcc83596",theme:"Tráfego pago, mídia e aquisição",quote:"só o manual eu tenho que lançar as vendas Mas também eu só entro com o produto, né? Eu já tenho o cadastro de preço, eu estava fazendo duas compras por mês. eu já estou começando a fazer uma compra maior. Eu estou querendo uma compra maior e eu divido os lançamentos. eu tenho que trazer novidades sempre, demanda bastante empenho aí nessa parte de marketing, Diferente de quando você tem um produto, né? Você não tem que criar todo o conceito em cima. duas compras para suprir a necessidade.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-6-fe33c705ab",theme:"Tráfego pago, mídia e aquisição",quote:"porque ele tem um descontinho do Pix, eu comecei a perceber que parcelando, Como eu ainda estou construindo caixa da empresa, eu estou num momento de crescimento, que eu vou conseguir acertar em anúncio, porque achar o produto estrela também é difícil, Hoje eu estou trabalhando com seis vezes, eu pretendo só reduzir e pagar vista. empresas que já tem um caixa sólido, porque aí você tem o desconto e você não está acumulando parcela no maior tempo.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-7-9079b3d9cd",theme:"Crédito, empréstimo, CET e bancos",quote:"quem ainda está construindo caixa da empresa, Você fala em questão de o que eu pago e o que eu tenho retorno. porque o meu mês eu pago na parcela, vai ser em torno do período da parcela mesmo, Depende de quanto eu conseguir crescer. cada mês eu estou crescendo mais e montando caixa de forma consciente. já teve momentos que eu passei dificuldade, Aí eu tinha que pegar o meu dinheiro, vou colocar meu dinheiro como pessoa física e colocar na empresa.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-8-22c238194d",theme:"Crédito, empréstimo, CET e bancos",quote:"Porque até você entender como o nicho funciona, Não é para você criar um e-commerce previsível, ali a margem de faturamento que vai dar certo para pagar todas as contas, Então é lógico que teve algumas vezes que eu tive que pegar da minha reserva, então eu evito ao máximo pegar crédito, eu prefiro pegar da minha reserva financeira. Mas eu sei que nem todo mundo tem uma reserva financeira que pode colocar o negócio, eu controlo muito pra saber o que eu tô fazendo e não ter que chegar nesse ponto.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-9-00862cf7cd",theme:"Tráfego pago, mídia e aquisição",quote:"pra mim que tá sendo a grande virada, eu saí de seis pra dez mil de faturamento, onde eu consegui começar a montar um caixa melhor pra empresa. porque eu sei que eu tenho uma longa jornada ainda de crescimento e eu estou com um crescimento conservador, ter uma estabilidade de conversão para ir escalando, porque eu quero uma escalação de longo prazo, E para isso é necessário você ter um pouco de cautela. eu cheguei a ver a tarja de anúncios já.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-10-16c9beac9e",theme:"Crédito, empréstimo, CET e bancos",quote:"Na verdade eu acho que é mais o que eu tenho, meus princípios de gestão financeira. Hoje eu já estou chegando no momento que eu consigo pagar minhas contas. Eu já estou chegando na estabilidade que eu estou buscando e aí eu quero fazer a escalação. Então eu não vejo a necessidade de buscar um crédito no momento atual.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-11-6693e607b6",theme:"Contexto da loja e operação",quote:"Então ela já me ensinou desde pequena, investimentos Eu tenho grandes investimentos no exterior, Brasil e tudo mais Então eu fujo disso o máximo possível, entendeu? Desde o meu primeiro emprego eu já tenho o meu cofrinho de investimentos De saber aguardar o dinheiro, colocar ele pra trabalhar pra você Então eu não busco esse tipo de produto mesmo Perfeito, eu penso em usar meu dinheiro pessoal física. Mas é claro que a princípio eu penso em crescer a empresa e montar o caixa da empresa para investir nela mesma.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-12-cb4199e060",theme:"Contexto da loja e operação",quote:"Hoje mesmo eu já tenho o meu Prolabore e tenho o caixa da empresa que eu estou só aumentando. eu tenho o caixa da empresa que eu coloco para investir também, onde eu vou reinvestindo dentro da empresa. porque eu sei que o faturamento que eu estou não dá para manter o meio até o final do ano.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-13-d48608eb1e",theme:"Crédito, empréstimo, CET e bancos",quote:"está sendo para fazer a transição para uma microempresa, que é onde eu vou ter que ter contadora, eu não vou pegar empréstimo e comprar um escritório, eu vou montar um caixa para fazer ação, partir do meu parabólico e tudo mais que eu tenho investido.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-14-853ade85b1",theme:"Tráfego pago, mídia e aquisição",quote:"eu acho que o maior aperto que eu tive logo no começo, que você gasta muito com anúncio e o anúncio não se paga, Eu acho que é o pé direito de todo mundo, Mas é aquela parte que todo mundo passa de acertar o criativo, Depois que você começa a acertar isso, Desde o princípio eu tinha muita mentalidade de que eu sei que no pessoal para pessoa o artesanato dos grupos você consegue vender. Só que assim eu sempre pensei em escala. Se eu quero ser grande eu tenho que vender o Brasil não é para o meu vizinho.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-15-af2cd1d9f6",theme:"Tráfego pago, mídia e aquisição",quote:"eu sempre quis um meta-eds que roda, Por isso que eu nunca foquei desde o começo em, eu quero vender para os meus amiguinhos, só para as pessoas que estão perto de mim, Ficar ali fazendo livezinha para regional, Eu sempre quis expandir e ver o Brasil, para já começar podendo escalar ainda mais. Eu só acho que muitas funcionalidades aí vem preso a aplicativos para executar, que eu acho que vocês estão nessa transição de trazer funcionalidades para a loja, porque a maioria das plataformas cobra mensal.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-16-5057f3a219",theme:"Contexto da loja e operação",quote:"dependendo se você emitiu 1 ou 200 notas. vocês só colocaram por nota emitida. Eu acho que vocês estão trazendo vários recursos novos muito bacanas para quem está desenvolvendo loja. E eu só estou no aguardo aí das melhorias de temas, de o que vocês vão trazer de novidade. mas eu já estou vendo o IASC fazer isso, porque eu estou muito ligada em tecnologia também. Inclusive, eu estou fazendo curso de IA para me implementar na minha loja.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14 (7)-17-9b0544aacb",theme:"Contexto da loja e operação",quote:"eu estou sempre buscando estar à frente do mercado e buscando tecnologias novas e formas de agilidade, A gente conseguir ter melhores resultados com menor tempo de produção.",citedBy:"Aline"},{id:"dovetail-transcript-2026-04-14-0-6461f0d786",theme:"Plataforma, Nuvemshop e integrações",quote:"A minha loja ela esses dias eu até li o resumo que vocês mandaram de 2025. a minha loja não se enquadra muito ali no maior tipo de comércio que vocês trabalham, porque eu vendo materiais e insumos para quem trabalha com corte a laser. de MDF e coisas para as pessoas personalizarem ali com máquinas a laser. Mas entra muito ali no ramo de artesanato, E faça você mesmo mais para esse campo E eu tenho essa loja há três anos, na verdade E eu conheci a Nuvemshop em propagandas de internet mesmo.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-1-c141480d23",theme:"Tráfego pago, mídia e aquisição",quote:"Então eu já trabalhava com o Instagram, com a Hotmart E aí a gente precisava de um site para pôr os produtos físicos E aí... Tá bom, E aí a gente foi ali naquele momento procurando alguma... A gente queria algo que a gente não precisasse de outras pessoas para desenvolver o site. Então eu não queria ter desenvolvedor, a gente tá na Nuvemshop por conta disso, e por isso que a gente optou pela Nuvemshop, e é por isso que a gente tá com a Nuvemshop até hoje.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-2-1e10961fbe",theme:"Tráfego pago, mídia e aquisição",quote:"Agora tá fazendo pelo Pinterest também, a gente ensina as pessoas a usar e faz o funil para o site, para elas comprarem o material do que a gente está ensinando. A gente iniciou direto na Nuvemshop, a gente já sabia que era inviável vender pelo WhatsApp. a gente precisava de um mínimo de estrutura, porque como a gente vende uma combinação muito grande de materiais, então eu tenho um material de 10 espessuras com 200 cores. Então ficaria inviável ter uma planilha de Excel para fazer isso.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-3-7dabf81ead",theme:"Tráfego pago, mídia e aquisição",quote:"e a gente tem uma parte de vendas de máquinas, que a gente está fazendo uma transição para o e-commerce, A gente não conseguiu se adaptar no site, então a gente tem essas três divisões da mesma empresa, contas a pagar e a receber sou eu que cuido e marketing. O que eu não cuido é de operacional, E eu também não cuido da parte de criação de design para mídias. Mas o restante da administração sou eu que faço. mas a gente não tem um estoque grande por conta de espaço.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-4-d7ee4c4431",theme:"Fornecedor, estoque e logística",quote:"A gente compra o material em placas grandes, então a gente não tem espaço para deixar, Então a gente tem esse giro semanal, com exceção de algumas coisas que a gente está começando a importar, mas a maioria dos materiais são semanais, Toda semana a gente tem compra de produto, porque tem muito da confiança dos fornecedores, Há pouquíssimo tempo a gente tinha que pagar a vista, Então agora a gente consegue já trabalhar mais essa questão do prazo.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-5-e6535e0b49",theme:"Contexto da loja e operação",quote:"Como eu já trabalhava com comércio também já estava um tempo na parte de infoproduto a gente já começou esse negócio certo, Então a gente já tinha um capital de giro. A gente sabia que a gente ia precisar desse giro.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-6-9f30e791a5",theme:"Crédito, empréstimo, CET e bancos",quote:"Então a gente nunca pegou financiamento para fazer giro, tudo aquilo que é material de venda, aquilo que vai entrar na loja e vai ser vendido, algumas coisas que a gente comprava para infraestrutura da loja, vamos comprar alguma coisa para mudar aqui a logística, até 2025 eu estava muito focada em marketing, e aí a gente passou por muitos momentos de ruptura de fornecimento, vendeu mais do que a gente achou que ia vender, só que o fornecedor precisa de três, por falta de planejamento logístico, mas a gente já teve empréstimo em banco, a gente já precisou mudar para um centro de logística maior, e ali a gente precisava de investir em rede elétrica, então a gente já usou capital de empréstimo para isso.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-7-46768e2131",theme:"Crédito, empréstimo, CET e bancos",quote:"a gente acabou fazendo um empréstimo, E a gente pagou com o próprio dinheiro da loja, E a gente conseguiu quitar nesse período de um ano, que foi também o suficiente para a gente depois já precisar mudar para outro lugar, mas aí faltou algum dinheiro para comprar material. nesse caso a gente não teve nenhum tipo... Obviamente, sempre é um juros muito além do que a gente gostaria. Também tem a questão do... A gente usou, a gente teve que pegar todo o crédito.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-8-682fb37a5f",theme:"Crédito, empréstimo, CET e bancos",quote:"Quando a gente pegou aquele crédito, a gente ficou sem mais nada disponível de crédito. porque a gente tinha mais crédito antes, e quando a gente pegou uma parte desse crédito, depois ele atualizou e a gente ficou sem crédito. Então, foi uma coisa que a gente não gostou por parte do banco, a gente utilizou e deu certo no final, Mas eles seriam essas duas questões, E essa questão da gente ficar depois sem crédito.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-9-55e36a77ae",theme:"Crédito, empréstimo, CET e bancos",quote:"Era uma oferta que a gente tinha até 50 mil e a gente não usou tudo porque a gente não quis e a gente achou que esse crédito ia ficar lá se precisasse para mais alguma coisa. Mas foi essa lógica mesmo que você falou, então ela não estava depois mais disponível. o que está disponível é exatamente isso aí, o que eu imagino é cartão de crédito. Quando eu preciso de alguma coisa ali a curto prazo ou emergencial, Você tinha que ter o saldo em conta e eles já debitavam.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-10-f2fdd0f1d3",theme:"Crédito, empréstimo, CET e bancos",quote:"Não precisar também ficar se preocupando em pagar boleto no dia, aí toda parte de dinheiro sou eu mesmo. aparece na tela inicial o crédito disponível. nem juros eu cheguei a ver quanto era, e o risco de você também não pagar é menor. Então você já não conta mais com aquele saldo. que eu não uso crédito para produto, mas sempre para uma situação de infraestrutura ou de crescimento e investimento mais, que não é relacionado a fornecimento material, para a gente é melhor o longo prazo e parcelas pequenas.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-11-7332a825ca",theme:"Prazo, carência e parcelamento",quote:"a gente tá precisando de uma estrutura nova, eu vou usar a vida toda da minha loja. o ideal seria que eu pagasse ele no mesmo giro de venda. Então se eu vou comprar um material e eu vou vendê-lo em 30 dias, o ideal seria que eu pagasse isso em 30 dias, Então a gente está abastecido para vender agora até o dia 8 produto de Dia das Mulheres. Então vamos supor que eu precisasse desse capital.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-12-070d6861f4",theme:"Crédito, empréstimo, CET e bancos",quote:"O ideal para mim seria o menor juros possível, porque as pessoas aqui compram parcelado em duas, Então seria pagar com juros menor já quando vendi essa mercadoria, porque não faria sentido eu pagar uma mercadoria que eu já vendi em 12 vezes, Isso daí ia criar um desbalanço no caixa ali.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-13-63d8f6d794",theme:"Crédito, empréstimo, CET e bancos",quote:"dessa parte desse assunto de crédito, aí talvez eu entre em contato com vocês para tirar alguma dúvida Mas eu vejo que ele sempre aparece, que tem disponível em várias telas ali Que eu estou fazendo as atividades, se vocês pudessem, só levar alguma sugestão para o time de vocês da parte fiscal que eu gostaria de ter esse bate-papo também com alguém do time que está fazendo as integrações fiscais, porque eu estou tendo muito problema com as notas fiscais. mas ele está me dando muitas exceções.",citedBy:"Viviane"},{id:"dovetail-transcript-2026-04-14-14-212af2f800",theme:"Contexto da loja e operação",quote:"ele não tira nota para pedido manual, ele não tira nota quando tem alguma coisa lá do frete. são muitas regras e muitas exceções. Então, se o time de fiscal quiser ajudar a gente, Esse gift card aí eu vou usar pra ir num evento presencial esse ano.",citedBy:"Viviane"}];function sp(c){return c.trim().toLowerCase().normalize("NFD").replace(new RegExp("\\p{M}","gu"),"")}function cv(c){const A=sp(c);return A?Tt.filter(z=>{const p=`${z.theme} ${z.quote} ${z.citedBy}`;return sp(p).includes(A)}):[...Tt]}function dv({open:c,onClose:A,participantVideo:z,onParticipantVideoChange:p}){const R=E.useId(),L=E.useId(),X=E.useId(),[F,D]=E.useState(""),[_,Z]=E.useState(null),O=E.useRef(null),P=E.useMemo(()=>{const J=new Map;return Tt.forEach(ee=>{J.set(ee.theme,(J.get(ee.theme)??0)+1)}),[...J.entries()].sort((ee,ze)=>ze[1]-ee[1]).slice(0,8).map(([ee])=>ee)},[]),de=E.useMemo(()=>{const J=cv(F);return _?J.filter(ee=>ee.theme===_):J},[F,_]);E.useEffect(()=>{c||(D(""),Z(null))},[c]),E.useEffect(()=>{var J;z||(J=O.current)==null||J.pause()},[z]);const pe=()=>{p(null),A()},qe=()=>{if(z){p(null);return}A()};return c?s.jsx("div",{className:"pres-modal-backdrop",role:"presentation",onClick:qe,children:s.jsxs("div",{className:"pres-modal-dialog pres-modal-dialog--hypothesis",role:"dialog","aria-modal":"true","aria-labelledby":z?X:R,onClick:J=>J.stopPropagation(),children:[s.jsx("div",{className:"pres-modal-toolbar",children:z?s.jsxs(s.Fragment,{children:[s.jsx("h2",{className:"pres-h2 pres-modal-title",id:X,children:z.videoLabel??"Trecho em vídeo"}),s.jsxs("div",{className:"pres-modal-toolbar-actions",children:[s.jsx("button",{type:"button",className:"pres-btn pres-btn--ghost pres-modal-close",onClick:()=>p(null),children:"Voltar às evidências"}),s.jsx("button",{type