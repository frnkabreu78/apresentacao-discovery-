sumir dívidas para a reposição rotineira de estoque, os lojistas desenvolveram"," ",s.jsx("strong",{children:"mecanismos de defesa robustos"}),", adaptando estrategicamente as suas operações."]})}),s.jsxs("article",{className:"pres-summary-card pres-summary-card--emphasis pres-mecanismos-intro-roadmap","aria-labelledby":"mecanismos-intro-roadmap-title",children:[s.jsx("header",{className:"pres-mecanismos-intro-roadmap__header",children:s.jsx("h3",{className:"pres-summary-card__title pres-mecanismos-intro-roadmap__title",id:"mecanismos-intro-roadmap-title",children:"Quatro modelos de operação"})}),s.jsx("ol",{className:"pres-mecanismos-route-grid","aria-label":"Modelos apresentados nos próximos slides",children:Fv.map(c=>{const A=c.Icon;return s.jsxs("li",{className:`pres-mecanismo-route-tile pres-mecanismo-route-tile--tone-${c.tone}`,children:[s.jsxs("div",{className:"pres-mecanismo-route-tile__rail","aria-hidden":"true",children:[s.jsx("span",{className:"pres-mecanismo-route-tile__index",children:c.indexLabel}),s.jsx("span",{className:"pres-mecanismo-route-tile__icon-wrap",children:s.jsx(A,{})})]}),s.jsxs("div",{className:"pres-mecanismo-route-tile__body",children:[s.jsx("h4",{className:"pres-mecanismo-route-tile__title",children:c.title}),s.jsx("p",{className:"pres-mecanismo-route-tile__sub",children:c.subtitle})]})]},c.key)})})]})]})}function Pv({onOpenEvidenceVideo:c}){return s.jsxs("div",{className:"pres-stack pres-stack--readable pres-slide-inverted-palette",children:[s.jsx("h2",{className:"pres-h2",children:"Dropshipping (nacional ou internacional)"}),s.jsx("article",{className:"pres-summary-card",children:s.jsxs("p",{className:"pres-summary-card__text",children:["Neste modelo de ",s.jsx("strong",{children:"estoque zero"}),', o ciclo físico do dinheiro é invertido e protegido. O lojista realiza a venda primeiro, recebe o valor do cliente e só então utiliza esse capital para comprar a mercadoria a preço de atacado com o parceiro fornecedor, despachando o pedido. Isso elimina totalmente a necessidade de empréstimos para giro, pois não há dinheiro "preso" em prateleiras.']})}),s.jsxs("article",{className:"pres-summary-card pres-summary-card--emphasis",children:[s.jsx("h3",{className:"pres-summary-card__title",children:"Descasamento (inexistente)"}),s.jsx("p",{className:"pres-summary-card__text",children:'Por não manter estoque próprio e comprar sob demanda, não há dinheiro "preso" em prateleiras. Quando o cliente paga no cartão e o repasse demora dois dias, o lojista utiliza o seu próprio caixa para comprar a mercadoria sem sofrer aperto.'})]}),s.jsxs("article",{className:"pres-summary-card pres-summary-card--evidence",children:[s.jsx("h3",{className:"pres-summary-card__title",children:"Evidência"}),s.jsx("p",{className:"pres-summary-card__text pres-summary-card__quote",children:'"É dropshipping: não tenho camisas paradas em estoque. Vendeu, entrou o dinheiro, eu pago o fornecedor — o giro acompanha o fluxo, sem precisar de empréstimo para reposição."'}),s.jsxs("p",{className:"pres-summary-card__attribution",children:["Douglas Eusébio, Loja Dougie",s.jsx(Dt,{profileName:"Douglas Eusébio",onOpenEvidenceVideo:c})]})]})]})}function $v({onOpenEvidenceVideo:c}){return s.jsxs("div",{className:"pres-stack pres-stack--readable pres-slide-inverted-palette",children:[s.jsx("h2",{className:"pres-h2",children:"Produção sob demanda (just-in-time)"}),s.jsx("article",{className:"pres-summary-card",children:s.jsxs("p",{className:"pres-summary-card__text",children:["Muito comum entre lojistas focados em peças artesanais ou personalizadas, o fluxo opera na lógica de"," ",s.jsx("strong",{children:"vender para depois produzir"}),". O empreendedor utiliza a liquidez (o dinheiro que acabou de entrar da venda no site) para ir comprar a matéria-prima exata daquele pedido específico e fabricá-lo. Esse formato isenta a loja de dívidas longas, embora gere uma dependência de receber as vendas diariamente."]})}),s.jsxs("article",{className:"pres-summary-card pres-summary-card--emphasis",children:[s.jsx("h3",{className:"pres-summary-card__title",children:"Descasamento (dependência do recebimento diário)"}),s.jsx("p",{className:"pres-summary-card__text",children:"O negócio depende 100% da liquidez das vendas diárias para girar. Se o dinheiro da venda não estiver disponível para saque imediato, o lojista não consegue comprar a matéria-prima para fabricar e enviar o pedido."})]}),s.jsxs("article",{className:"pres-summary-card pres-summary-card--evidence",children:[s.jsx("h3",{className:"pres-summary-card__title",children:"Evidência"}),s.jsx("p",{className:"pres-summary-card__text pres-summary-card__quote",children:'"Aqui é sob demanda: fechei a venda, compro a matéria-prima daquele pedido e produzo. O que entra no dia é o que manda no giro — sem estoque parado e sem pegar empréstimo para insumo."'}),s.jsxs("p",{className:"pres-summary-card__attribution",children:["Mayke Gomes, Acessórios masculinos",s.jsx(Dt,{profileName:"Mayke Gomes",onOpenEvidenceVideo:c})]})]})]})}function Wv({onOpenEvidenceVideo:c}){return s.jsxs("div",{className:"pres-stack pres-stack--readable pres-slide-inverted-palette",children:[s.jsx("h2",{className:"pres-h2",children:"Autofinanciamento (capital próprio estruturado)"}),s.jsx("article",{className:"pres-summary-card",children:s.jsxs("p",{className:"pres-summary-card__text",children:['Lojistas com alta maturidade financeira estruturam os negócios para atuar como seus próprios "bancos", rejeitando o crédito externo e utilizando exclusivamente reservas financeiras próprias. A estratégia central desse grupo é manter o estoque ',s.jsx("strong",{children:"100% pago à vista"})," para forçar descontos com fornecedores."]})}),s.jsxs("article",{className:"pres-summary-card pres-summary-card--emphasis",children:[s.jsx("h3",{className:"pres-summary-card__title",children:"Publicidade de crédito (sem engajamento)"}),s.jsx("p",{className:"pres-summary-card__text",children:'A lojista viu a publicidade de crédito, mas não engajou. Possui dinheiro aplicado rendendo e considera qualquer juro de empréstimo como "despesa desnecessária".'})]}),s.jsxs("article",{className:"pres-summary-card pres-summary-card--evidence",children:[s.jsx("h3",{className:"pres-summary-card__title",children:"Evidência"}),s.jsx("p",{className:"pres-summary-card__text pres-summary-card__quote",children:'"A operação é com capital próprio e compra à vista: eu fecho o desconto no fornecedor e não pago juro de empréstimo que não fecha a conta — quando preciso, o banco já me dá linha mais barata."'}),s.jsxs("p",{className:"pres-summary-card__attribution",children:["Andressa Sanches, Moda feminina",s.jsx(Dt,{profileName:"Andressa Sanches",onOpenEvidenceVideo:c})]})]})]})}function eg({onOpenEvidenceVideo:c}){return s.jsxs("div",{className:"pres-stack pres-stack--readable pres-slide-inverted-palette pres-slide-mecanismo-fornecedor",children:[s.jsx("h2",{className:"pres-h2",children:"Alavancagem direta com o fornecedor"}),s.jsx("article",{className:"pres-summary-card",children:s.jsxs("p",{className:"pres-summary-card__text",children:["Em vez de pegar dinheiro emprestado com bancos ou plataformas, lojas mais tracionadas utilizam o tempo de relacionamento e o volume de compras para negociar ",s.jsx("strong",{children:"prazos alongados de pagamento"})," (como 30 ou 60 dias) diretamente com os fabricantes dos insumos. Outra tática, ainda em fase de construção de caixa, é diluir o pagamento do fornecedor nas parcelas do ",s.jsx("strong",{children:"cartão de crédito da própria empresa"}),", evitando dívidas com terceiros."]})}),s.jsxs("article",{className:"pres-summary-card pres-summary-card--emphasis",children:[s.jsx("h3",{className:"pres-summary-card__title",children:"O Gatilho Real (Infraestrutura, não estoque)"}),s.jsx("p",{className:"pres-summary-card__text",children:"As rupturas de estoque ocorrem por lead time do fornecedor (logística), não por falta de capital. O único gatilho que a fez buscar crédito externo até hoje foi a necessidade de expansão física."})]}),s.jsxs("article",{className:"pres-summary-card pres-summary-card--evidence",children:[s.jsx("h3",{className:"pres-summary-card__title",children:"Evidência"}),s.jsx("p",{className:"pres-summary-card__text pres-summary-card__quote",children:'"A gente já precisou mudar para um centro de logística maior, e ali a gente precisava de investir em rede elétrica, estantes, então a gente já usou capital de empréstimo para isso."'}),s.jsxs("p",{className:"pres-summary-card__attribution",children:["Viviane, proprietária da loja Color Zeds",s.jsx(Dt,{profileName:"Viviane",onOpenEvidenceVideo:c})]})]})]})}const Mt="/api/comments";async function Fn(c){try{const A=await fetch(`${Mt}?slide=${c}`);if(!A.ok)return[];const z=await A.json();return Array.isArray(z)?z:[]}catch{return[]}}async function ag(c){try{return(await fetch(Mt,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(c)})).ok}catch{return!1}}async function sg(c){try{return(await fetch(`${Mt}/${c}`,{method:"DELETE"})).ok}catch{return!1}}async function lg(c,A){try{return(await fetch(`${Mt}/${c}`,{method:"PUT",headers:{"Content-Type":"application/json"},body:JSON.stringify({text:A})})).ok}catch{return!1}}function ig({slideIndex:c}){const[A,z]=E.useState(!1),[p,R]=E.useState([]),[L,X]=E.useState(""),[F,D]=E.useState(""),[_,Z]=E.useState(!1),[O,P]=E.useState(!1),[de,pe]=E.useState(!1),[qe,J]=E.useState(null),[ee,ze]=E.useState(""),[xe,fe]=E.useState(null),Ze=E.useRef(null),Ce=E.useRef(null);E.useEffect(()=>{R([]),P(!1),J(null),Fn(c).then(R)},[c]),E.useEffect(()=>{A&&(pe(!0),Fn(c).then(H=>{R(H),pe(!1)}))},[A,c]),E.useEffect(()=>{A&&setTimeout(()=>{var H;return(H=Ce.current)==null?void 0:H.focus()},50)},[A]),E.useEffect(()=>{if(!A)return;const H=De=>{De.key==="Escape"&&(qe?J(null):z(!1))};return document.addEventListener("keydown",H),()=>document.removeEventListener("keydown",H)},[A,qe]);const K=async H=>{if(H.preventDefault(),!F.trim())return;Z(