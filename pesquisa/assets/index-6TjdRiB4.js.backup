. Valor: peso alto de CET, prazo e flexibilidade para quitar, com resistência a empréstimo longo em parcelas fixas. Cobrança: tensão entre retenção automática e controlo explícito do caixa. Heterogeneidade de perfis: mercado diverso, do caixa pressionado ao capital próprio, exigindo produtos sob medida e comunicação segmentada.";function Qv(){return s.jsxs("section",{className:"pres-myth-slide pres-myth-slide--asset","aria-labelledby":"sec-sumario-executivo-achados",children:[s.jsx("h2",{className:"pres-sr-only",id:"sec-sumario-executivo-achados",children:"Sumário executivo dos achados"}),s.jsx(Ha,{src:kv,alt:Yv})]})}const In=[{id:"abertura-contexto",label:"Abertura e contexto",slides:[{slideIndex:0,label:"Capa"},{slideIndex:1,label:"Além da superfície: ciclo financeiro real"},{slideIndex:2,label:"O que queríamos responder"},{slideIndex:3,label:"Temas que guiaram o roteiro"},{slideIndex:4,label:"Duas lentes de análise"},{slideIndex:5,label:"Amostragem e método"},{slideIndex:6,label:"Hipóteses iniciais por tema"}]},{id:"perfis-segmentacao",label:"Perfis e segmentação",slides:[{slideIndex:7,label:"Perfis entrevistados — parte 1"},{slideIndex:8,label:"Perfis entrevistados — parte 2"},{slideIndex:9,label:"Arquétipos comportamentais"},{slideIndex:10,label:"Sumário executivo dos achados"},{slideIndex:11,label:"Mitos vs realidade (síntese)"},{slideIndex:12,label:"Veredito da hipótese inicial"}]},{id:"diagnostico-estrategico",label:"Diagnóstico estratégico",slides:[{slideIndex:13,label:"Onde o caixa realmente sangra"},{slideIndex:14,label:"Resumo dos achados (vídeo)"},{slideIndex:15,label:"Mecanismos de defesa — visão geral"},{slideIndex:16,label:"Mecanismo: dropshipping"},{slideIndex:17,label:"Mecanismo: produção sob demanda"},{slideIndex:18,label:"Mecanismo: autofinanciamento"},{slideIndex:19,label:"Mecanismo: alavancagem fornecedor"},{slideIndex:20,label:"Matriz diagnóstica: fit de crédito"}]},{id:"aderencia-casos",label:"Aderência e casos",slides:[{slideIndex:21,label:"